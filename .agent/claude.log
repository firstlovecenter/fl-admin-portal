{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NH1MPScLrN8Hohk45cbvuM","type":"tool_result","content":"1\t/**\n2\t * UpdateMember.test.tsx — SYN-205\n3\t *\n4\t * Bug: submitting an email-address change on a member's profile silently\n5\t * \"succeeded\" client-side (form closed, navigated away) even when the\n6\t * backend rejected the write for a duplicate email/whatsapp collision.\n7\t *\n8\t * Root cause: the Apollo Client used by this app is configured with\n9\t * `errorPolicy: 'all'` (see createApolloClient.tsx, SYN-178) so that GraphQL\n10\t * errors are attached to `result.errors` instead of rejecting the mutation\n11\t * promise. `onSubmit` only had a `try/catch` around `await UpdateMember(...)`\n12\t * to detect the collision and route to <MemberCollisionDialog>. Since the\n13\t * promise never rejected, that catch block never ran — the code fell\n14\t * straight through to the \"success\" path (bacenta/basonta follow-up\n15\t * mutations, resetForm, navigate away) while nothing had actually been\n16\t * saved.\n17\t *\n18\t * Fix: `onSubmit` now inspects `updateResult.errors` explicitly. A\n19\t * collision routes to <MemberCollisionDialog> exactly like the (still\n20\t * present, now effectively a fallback) catch block did before; a\n21\t * non-collision GraphQL error surfaces a toast via displayError and stops\n22\t * before the follow-up mutations/navigation run.\n23\t *\n24\t * These tests render the real <UpdateMember /> against a MockedProvider\n25\t * with `errorPolicy: 'all'` on the mutate default (matching prod config)\n26\t * so they fail against the pre-fix code and pass against the fix.\n27\t */\n28\t\n29\timport React from 'react'\n30\timport { describe, it, expect, vi, afterEach, beforeAll } from 'vitest'\n31\timport { render, screen, waitFor, cleanup } from '@testing-library/react'\n32\timport userEvent from '@testing-library/user-event'\n33\timport { MemoryRouter } from 'react-router-dom'\n34\timport { MockedProvider, MockedResponse } from '@apollo/client/testing'\n35\t\n36\timport UpdateMember from './UpdateMember'\n37\timport { UPDATE_MEMBER_MUTATION } from './UpdateMutations'\n38\timport {\n39\t  DISPLAY_MEMBER_BIO,\n40\t  DISPLAY_MEMBER_CHURCH,\n41\t} from '../display/ReadQueries'\n42\timport { GET_CAMPUS_BASONTAS } from 'queries/ListQueries'\n43\timport { MEMBER_BACENTA_SEARCH } from 'components/formik/SearchBacentaQueries'\n44\timport { MemberContext } from 'contexts/MemberContext'\n45\timport { ChurchContext } from 'contexts/ChurchContext'\n46\t\n47\tvi.mock('react-router-dom', async () => {\n48\t  const actual =\n49\t    await vi.importActual<typeof import('react-router-dom')>('react-router-dom')\n50\t  return {\n51\t    ...actual,\n52\t    useNavigate: () => mockNavigate,\n53\t  }\n54\t})\n55\t\n56\t// RoleView (rendered by MemberForm for the Add Title / Delete buttons) →\n57\t// useAuth (auth/useAuth) → useAuth (contexts/AuthContext). Mock the context\n58\t// so isAuthorised gates purely on currentUser.roles, matching the\n59\t// ServicesMenu.test.tsx pattern elsewhere in this repo.\n60\tvi.mock('contexts/AuthContext', () => ({\n61\t  useAuth: vi.fn(() => ({ isAuthenticated: true })),\n62\t}))\n63\t\n64\tconst mockNavigate = vi.fn()\n65\t\n66\t// jsdom has no ResizeObserver; the cmdk-powered bacenta search combobox\n67\t// (SearchCombobox / SearchBacenta) requires one to mount.\n68\tbeforeAll(() => {\n69\t  class ResizeObserverStub {\n70\t    observe() {}\n71\t    unobserve() {}\n72\t    disconnect() {}\n73\t  }\n74\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n75\t  ;(globalThis as any).ResizeObserver = ResizeObserverStub\n76\t})\n77\t\n78\tafterEach(() => {\n79\t  cleanup()\n80\t  mockNavigate.mockClear()\n81\t})\n82\t\n83\tconst MEMBER_ID = 'member-1'\n84\tconst BACENTA_ID = 'bacenta-1'\n85\tconst CAMPUS_ID = 'campus-1'\n86\t\n87\tconst memberBioMock = {\n88\t  request: { query: DISPLAY_MEMBER_BIO, variables: { id: MEMBER_ID } },\n89\t  result: {\n90\t    data: {\n91\t      members: [\n92\t        {\n93\t          id: MEMBER_ID,\n94\t          firstName: 'Ama',\n95\t          middleName: '',\n96\t          lastName: 'Mensah',\n97\t          fullName: 'Ama Mensah',\n98\t          nameWithTitle: 'Ama Mensah',\n99\t          currentTitle: null,\n100\t          email: 'ama@example.com',\n101\t          phoneNumber: '233241111111',\n102\t          stickyNote: '',\n103\t          pictureUrl: 'https://example.com/pic.jpg',\n104\t          visitationArea: 'no-location',\n105\t          whatsappNumber: '233241111111',\n106\t          dob: { date: '1990-01-01' },\n107\t          gender: { gender: 'Female' },\n108\t          maritalStatus: { status: 'Single' },\n109\t          occupation: { occupation: 'Teacher' },\n110\t        },\n111\t      ],\n112\t    },\n113\t  },\n114\t}\n115\t\n116\tconst memberChurchMock = {\n117\t  request: { query: DISPLAY_MEMBER_CHURCH, variables: { id: MEMBER_ID } },\n118\t  result: {\n119\t    data: {\n120\t      members: [\n121\t        {\n122\t          id: MEMBER_ID,\n123\t          bacenta: {\n124\t            id: BACENTA_ID,\n125\t            name: 'Grace Bacenta',\n126\t            leader: { firstName: 'Kofi', lastName: 'Boateng' },\n127\t            council: {\n128\t              id: 'council-1',\n129\t              name: 'Central Council',\n130\t              leader: {\n131\t                id: 'leader-1',\n132\t                firstName: 'Kwame',\n133\t                lastName: 'Owusu',\n134\t                fullName: 'Kwame Owusu',\n135\t              },\n136\t            },\n137\t          },\n138\t          bacentaSummary: { id: BACENTA_ID, name: 'Grace Bacenta' },\n139\t          basonta: null,\n140\t          history: [],\n141\t        },\n142\t      ],\n143\t    },\n144\t  },\n145\t}\n146\t\n147\tconst basontasMock = {\n148\t  request: { query: GET_CAMPUS_BASONTAS, variables: { id: CAMPUS_ID } },\n149\t  result: {\n150\t    data: {\n151\t      campuses: [{ id: CAMPUS_ID, name: 'Main Campus', basontas: [] }],\n152\t    },\n153\t  },\n154\t}\n155\t\n156\t// SearchBacenta debounces (DEBOUNCE_TIMER=500ms) then always fires\n157\t// MEMBER_BACENTA_SEARCH for the initial bacenta name value seeded from\n158\t// memberChurchMock ('Grace Bacenta'). Match on the query alone (any\n159\t// variables) since the exact key/id aren't the point of this test and\n160\t// MockedProvider's default requires an exact variables match otherwise.\n161\tconst memberBacentaSearchMock = {\n162\t  request: { query: MEMBER_BACENTA_SEARCH },\n163\t  variableMatcher: () => true,\n164\t  result: {\n165\t    data: {\n166\t      members: [\n167\t        {\n168\t          id: MEMBER_ID,\n169\t          bacentaSearch: [\n170\t            { id: BACENTA_ID, name: 'Grace Bacenta', governorship: null },\n171\t          ],\n172\t        },\n173\t      ],\n174\t    },\n175\t  },\n176\t}\n177\t\n178\tconst collisionUpdateMock = (variables: Record<string, unknown>) => ({\n179\t  request: { query: UPDATE_MEMBER_MUTATION, variables },\n180\t  result: {\n181\t    data: { UpdateMemberDetails: null },\n182\t    errors: [\n183\t      {\n184\t        message: 'This email already belongs to another member',\n185\t        extensions: {\n186\t          collision: {\n187\t            field: 'email',\n188\t            status: 'active',\n189\t            memberId: 'other-member-1',\n190\t            firstName: 'Kofi',\n191\t            lastName: 'Asante',\n192\t            bacentaName: 'Faith Bacenta',\n193\t          },\n194\t        },\n195\t      },\n196\t    ],\n197\t  },\n198\t})\n199\t\n200\tconst successUpdateMock = (variables: Record<string, unknown>) => ({\n201\t  request: { query: UPDATE_MEMBER_MUTATION, variables },\n202\t  result: {\n203\t    data: {\n204\t      UpdateMemberDetails: {\n205\t        firstName: 'Ama',\n206\t        middleName: '',\n207\t        lastName: 'Mensah',\n208\t        fullName: 'Ama Mensah',\n209\t        email: (variables.email as string) ?? 'ama@example.com',\n210\t        phoneNumber: '233241111111',\n211\t        pictureUrl: 'https://example.com/pic.jpg',\n212\t        whatsappNumber: '233241111111',\n213\t        dob: { date: '1990-01-01' },\n214\t        gender: { gender: 'Female' },\n215\t        maritalStatus: { status: 'Single' },\n216\t        occupation: { occupation: 'Teacher' },\n217\t      },\n218\t    },\n219\t  },\n220\t})\n221\t\n222\tconst baseUpdateVariables = (email: string) => ({\n223\t  id: MEMBER_ID,\n224\t  firstName: 'Ama',\n225\t  middleName: '',\n226\t  lastName: 'Mensah',\n227\t  email,\n228\t  gender: 'Female',\n229\t  phoneNumber: '233241111111',\n230\t  whatsappNumber: '233241111111',\n231\t  dob: '1990-01-01',\n232\t  maritalStatus: 'Single',\n233\t  occupation: 'Teacher',\n234\t  pictureUrl: 'https://example.com/pic.jpg',\n235\t  bacenta: BACENTA_ID,\n236\t})\n237\t\n238\tconst renderUpdateMember = (mocks: readonly MockedResponse[]) =>\n239\t  render(\n240\t    <MemoryRouter initialEntries={['/member/edit']}>\n241\t      <MemberContext.Provider\n242\t        value={{\n243\t          memberId: MEMBER_ID,\n244\t          setMemberId: vi.fn(),\n245\t          // canChangeUniques() in MemberForm gates the Basic Info/Contact\n246\t          // sections (where the email field lives) on\n247\t          // isAuthorised(permitAdmin('Governorship'), currentUser.roles).\n248\t          currentUser: { id: 'tester-1', roles: ['adminGovernorship'] },\n249\t        }}\n250\t      >\n251\t        <ChurchContext.Provider value={{ campusId: CAMPUS_ID }}>\n252\t          <MockedProvider\n253\t            mocks={mocks}\n254\t            addTypename={false}\n255\t            defaultOptions={{\n256\t              // Mirrors prod's createApolloClient defaultOptions.mutate:\n257\t              // GraphQL errors land in `result.errors`, they do not reject\n258\t              // the mutate() promise.\n259\t              mutate: { errorPolicy: 'all' },\n260\t              watchQuery: { errorPolicy: 'all' },\n261\t              query: { errorPolicy: 'all' },\n262\t            }}\n263\t          >\n264\t            <UpdateMember />\n265\t          </MockedProvider>\n266\t        </ChurchContext.Provider>\n267\t      </MemberContext.Provider>\n268\t    </MemoryRouter>\n269\t  )\n270\t\n271\t// SearchBacenta only writes to Formik's `bacenta` field via the search\n272\t// dropdown's onSelect — the initial value only seeds the *display text*,\n273\t// not formik.values.bacenta. A real user re-confirms the bacenta by\n274\t// picking it from the dropdown; do the same here so submission has a\n275\t// valid `bacenta` object regardless of query-resolution timing.\n276\tconst selectBacentaFromDropdown = async () => {\n277\t  const user = userEvent.setup()\n278\t  const bacentaInput = await screen.findByPlaceholderText(\n279\t    /start typing to search/i\n280\t  )\n281\t  await user.click(bacentaInput)\n282\t  await user.clear(bacentaInput)\n283\t  await user.type(bacentaInput, 'Grace')\n284\t  const option = await screen.findByText('Grace Bacenta')\n285\t  await user.click(option)\n286\t}\n287\t\n288\tconst submitForm = async () => {\n289\t  const user = userEvent.setup()\n290\t  const submitButton = await screen.findByRole('button', { name: /save/i })\n291\t  await user.click(submitButton)\n292\t}\n293\t\n294\tdescribe('UpdateMember — SYN-205 email-collision handling', () => {\n295\t  it('shows the collision dialog (does not navigate away) when the update returns a collision error', async () => {\n296\t    const variables = baseUpdateVariables('taken@example.com')\n297\t\n298\t    renderUpdateMember([\n299\t      memberBioMock,\n300\t      memberChurchMock,\n301\t      basontasMock,\n302\t      memberBacentaSearchMock,\n303\t      collisionUpdateMock(variables),\n304\t      // UpdateMember's useMutation always sets refetchQueries for these two\n305\t      // queries. Since errorPolicy: 'all' means mutate() resolves (rather\n306\t      // than rejects) even on a collision error, Apollo still runs the\n307\t      // refetch — so a second copy of each read is needed here too.\n308\t      memberBioMock,\n309\t      memberChurchMock,\n310\t    ])\n311\t\n312\t    await screen.findByDisplayValue('ama@example.com')\n313\t    await selectBacentaFromDropdown()\n314\t\n315\t    const emailInput = screen.getByLabelText(/email address/i)\n316\t    await userEvent.setup().clear(emailInput)\n317\t    await userEvent.setup().type(emailInput, 'taken@example.com')\n318\t\n319\t    await submitForm()\n320\t\n321\t    const description = await screen.findByText(\n322\t      (_, element) =>\n323\t        element?.getAttribute('data-slot') === 'dialog-description' &&\n324\t        (element?.textContent ?? '').includes('already belongs to')\n325\t    )\n326\t    expect(description).toBeInTheDocument()\n327\t    expect(screen.getByText(/Kofi Asante/)).toBeInTheDocument()\n328\t\n329\t    // The whole point of the bug: this must NOT have fired.\n330\t    expect(mockNavigate).not.toHaveBeenCalled()\n331\t  })\n332\t\n333\t  it('navigates away on a genuine successful update', async () => {\n334\t    const variables = baseUpdateVariables('newemail@example.com')\n335\t\n336\t    renderUpdateMember([\n337\t      memberBioMock,\n338\t      memberChurchMock,\n339\t      basontasMock,\n340\t      memberBacentaSearchMock,\n341\t      successUpdateMock(variables),\n342\t      memberBioMock,\n343\t      memberChurchMock,\n344\t    ])\n345\t\n346\t    await screen.findByDisplayValue('ama@example.com')\n347\t    await selectBacentaFromDropdown()\n348\t\n349\t    const emailInput = screen.getByLabelText(/email address/i)\n350\t    await userEvent.setup().clear(emailInput)\n351\t    await userEvent.setup().type(emailInput, 'newemail@example.com')\n352\t\n353\t    await submitForm()\n354\t\n355\t    await waitFor(() =>\n356\t      expect(mockNavigate).toHaveBeenCalledWith('/member/displaydetails')\n357\t    )\n358\t  })\n359\t})\n360\t"}]},"parent_tool_use_id":null,"session_id":"1f8dd599-a4b3-4691-9eeb-51a7fceb4862","uuid":"334ea0bb-7fc3-4898-ad3c-b60b112af224","timestamp":"2026-07-15T02:02:54.576Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/updatemember_test.tsx","content":"/**\n * UpdateMember.test.tsx — SYN-205\n *\n * Bug: submitting an email-address change on a member's profile silently\n * \"succeeded\" client-side (form closed, navigated away) even when the\n * backend rejected the write for a duplicate email/whatsapp collision.\n *\n * Root cause: the Apollo Client used by this app is configured with\n * `errorPolicy: 'all'` (see createApolloClient.tsx, SYN-178) so that GraphQL\n * errors are attached to `result.errors` instead of rejecting the mutation\n * promise. `onSubmit` only had a `try/catch` around `await UpdateMember(...)`\n * to detect the collision and route to <MemberCollisionDialog>. Since the\n * promise never rejected, that catch block never ran — the code fell\n * straight through to the \"success\" path (bacenta/basonta follow-up\n * mutations, resetForm, navigate away) while nothing had actually been\n * saved.\n *\n * Fix: `onSubmit` now inspects `updateResult.errors` explicitly. A\n * collision routes to <MemberCollisionDialog> exactly like the (still\n * present, now effectively a fallback) catch block did before; a\n * non-collision GraphQL error surfaces a toast via displayError and stops\n * before the follow-up mutations/navigation run.\n *\n * These tests render the real <UpdateMember /> against a MockedProvider\n * with `errorPolicy: 'all'` on the mutate default (matching prod config)\n * so they fail against the pre-fix code and pass against the fix.\n */\n\nimport React from 'react'\nimport { describe, it, expect, vi, afterEach, beforeAll } from 'vitest'\nimport { render, screen, waitFor, cleanup } from '@testing-library/react'\nimport userEvent from '@testing-library/user-event'\nimport { MemoryRouter } from 'react-router-dom'\nimport { MockedProvider, MockedResponse } from '@apollo/client/testing'\n\nimport UpdateMember from './UpdateMember'\nimport { UPDATE_MEMBER_MUTATION } from './UpdateMutations'\nimport {\n  DISPLAY_MEMBER_BIO,\n  DISPLAY_MEMBER_CHURCH,\n} from '../display/ReadQueries'\nimport { GET_CAMPUS_BASONTAS } from 'queries/ListQueries'\nimport { MEMBER_BACENTA_SEARCH } from 'components/formik/SearchBacentaQueries'\nimport { MemberContext } from 'contexts/MemberContext'\nimport { ChurchContext } from 'contexts/ChurchContext'\n\nvi.mock('react-router-dom', async () => {\n  const actual =\n    await vi.importActual<typeof import('react-router-dom')>('react-router-dom')\n  return {\n    ...actual,\n    useNavigate: () => mockNavigate,\n  }\n})\n\n// RoleView (rendered by MemberForm for the Add Title / Delete buttons) →\n// useAuth (auth/useAuth) → useAuth (contexts/AuthContext). Mock the context\n// so isAuthorised gates purely on currentUser.roles, matching the\n// ServicesMenu.test.tsx pattern elsewhere in this repo.\nvi.mock('contexts/AuthContext', () => ({\n  useAuth: vi.fn(() => ({ isAuthenticated: true })),\n}))\n\nconst mockNavigate = vi.fn()\n\n// jsdom has no ResizeObserver; the cmdk-powered bacenta search combobox\n// (SearchCombobox / SearchBacenta) requires one to mount.\nbeforeAll(() => {\n  class ResizeObserverStub {\n    observe() {}\n    unobserve() {}\n    disconnect() {}\n  }\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  ;(globalThis as any).ResizeObserver = ResizeObserverStub\n})\n\nafterEach(() => {\n  cleanup()\n  mockNavigate.mockClear()\n})\n\nconst MEMBER_ID = 'member-1'\nconst BACENTA_ID = 'bacenta-1'\nconst CAMPUS_ID = 'campus-1'\n\nconst memberBioMock = {\n  request: { query: DISPLAY_MEMBER_BIO, variables: { id: MEMBER_ID } },\n  result: {\n    data: {\n      members: [\n        {\n          id: MEMBER_ID,\n          firstName: 'Ama',\n          middleName: '',\n          lastName: 'Mensah',\n          fullName: 'Ama Mensah',\n          nameWithTitle: 'Ama Mensah',\n          currentTitle: null,\n          email: 'ama@example.com',\n          phoneNumber: '233241111111',\n          stickyNote: '',\n          pictureUrl: 'https://example.com/pic.jpg',\n          visitationArea: 'no-location',\n          whatsappNumber: '233241111111',\n          dob: { date: '1990-01-01' },\n          gender: { gender: 'Female' },\n          maritalStatus: { status: 'Single' },\n          occupation: { occupation: 'Teacher' },\n        },\n      ],\n    },\n  },\n}\n\nconst memberChurchMock = {\n  request: { query: DISPLAY_MEMBER_CHURCH, variables: { id: MEMBER_ID } },\n  result: {\n    data: {\n      members: [\n        {\n          id: MEMBER_ID,\n          bacenta: {\n            id: BACENTA_ID,\n            name: 'Grace Bacenta',\n            leader: { firstName: 'Kofi', lastName: 'Boateng' },\n            council: {\n              id: 'council-1',\n              name: 'Central Council',\n              leader: {\n                id: 'leader-1',\n                firstName: 'Kwame',\n                lastName: 'Owusu',\n                fullName: 'Kwame Owusu',\n              },\n            },\n          },\n          bacentaSummary: { id: BACENTA_ID, name: 'Grace Bacenta' },\n          basonta: null,\n          history: [],\n        },\n      ],\n    },\n  },\n}\n\nconst basontasMock = {\n  request: { query: GET_CAMPUS_BASONTAS, variables: { id: CAMPUS_ID } },\n  result: {\n    data: {\n      campuses: [{ id: CAMPUS_ID, name: 'Main Campus', basontas: [] }],\n    },\n  },\n}\n\n// SearchBacenta debounces (DEBOUNCE_TIMER=500ms) then always fires\n// MEMBER_BACENTA_SEARCH for the initial bacenta name value seeded from\n// memberChurchMock ('Grace Bacenta'). Match on the query alone (any\n// variables) since the exact key/id aren't the point of this test and\n// MockedProvider's default requires an exact variables match otherwise.\nconst memberBacentaSearchMock = {\n  request: { query: MEMBER_BACENTA_SEARCH },\n  variableMatcher: () => true,\n  result: {\n    data: {\n      members: [\n        {\n          id: MEMBER_ID,\n          bacentaSearch: [\n            { id: BACENTA_ID, name: 'Grace Bacenta', governorship: null },\n          ],\n        },\n      ],\n    },\n  },\n}\n\nconst collisionUpdateMock = (variables: Record<string, unknown>) => ({\n  request: { query: UPDATE_MEMBER_MUTATION, variables },\n  result: {\n    data: { UpdateMemberDetails: null },\n    errors: [\n      {\n        message: 'This email already belongs to another member',\n        extensions: {\n          collision: {\n            field: 'email',\n            status: 'active',\n            memberId: 'other-member-1',\n            firstName: 'Kofi',\n            lastName: 'Asante',\n            bacentaName: 'Faith Bacenta',\n          },\n        },\n      },\n    ],\n  },\n})\n\nconst successUpdateMock = (variables: Record<string, unknown>) => ({\n  request: { query: UPDATE_MEMBER_MUTATION, variables },\n  result: {\n    data: {\n      UpdateMemberDetails: {\n        firstName: 'Ama',\n        middleName: '',\n        lastName: 'Mensah',\n        fullName: 'Ama Mensah',\n        email: (variables.email as string) ?? 'ama@example.com',\n        phoneNumber: '233241111111',\n        pictureUrl: 'https://example.com/pic.jpg',\n        whatsappNumber: '233241111111',\n        dob: { date: '1990-01-01' },\n        gender: { gender: 'Female' },\n        maritalStatus: { status: 'Single' },\n        occupation: { occupation: 'Teacher' },\n      },\n    },\n  },\n})\n\nconst baseUpdateVariables = (email: string) => ({\n  id: MEMBER_ID,\n  firstName: 'Ama',\n  middleName: '',\n  lastName: 'Mensah',\n  email,\n  gender: 'Female',\n  phoneNumber: '233241111111',\n  whatsappNumber: '233241111111',\n  dob: '1990-01-01',\n  maritalStatus: 'Single',\n  occupation: 'Teacher',\n  pictureUrl: 'https://example.com/pic.jpg',\n  bacenta: BACENTA_ID,\n})\n\nconst renderUpdateMember = (mocks: readonly MockedResponse[]) =>\n  render(\n    <MemoryRouter initialEntries={['/member/edit']}>\n      <MemberContext.Provider\n        value={{\n          memberId: MEMBER_ID,\n          setMemberId: vi.fn(),\n          // canChangeUniques() in MemberForm gates the Basic Info/Contact\n          // sections (where the email field lives) on\n          // isAuthorised(permitAdmin('Governorship'), currentUser.roles).\n          currentUser: { id: 'tester-1', roles: ['adminGovernorship'] },\n        }}\n      >\n        <ChurchContext.Provider value={{ campusId: CAMPUS_ID }}>\n          <MockedProvider\n            mocks={mocks}\n            addTypename={false}\n            defaultOptions={{\n              // Mirrors prod's createApolloClient defaultOptions.mutate:\n              // GraphQL errors land in `result.errors`, they do not reject\n              // the mutate() promise.\n              mutate: { errorPolicy: 'all' },\n              watchQuery: { errorPolicy: 'all' },\n              query: { errorPolicy: 'all' },\n            }}\n          >\n            <UpdateMember />\n          </MockedProvider>\n        </ChurchContext.Provider>\n      </MemberContext.Provider>\n    </MemoryRouter>\n  )\n\n// SearchBacenta only writes to Formik's `bacenta` field via the search\n// dropdown's onSelect — the initial value only seeds the *display text*,\n// not formik.values.bacenta. A real user re-confirms the bacenta by\n// picking it from the dropdown; do the same here so submission has a\n// valid `bacenta` object regardless of query-resolution timing.\nconst selectBacentaFromDropdown = async () => {\n  const user = userEvent.setup()\n  const bacentaInput = await screen.findByPlaceholderText(\n    /start typing to search/i\n  )\n  await user.click(bacentaInput)\n  await user.clear(bacentaInput)\n  await user.type(bacentaInput, 'Grace')\n  const option = await screen.findByText('Grace Bacenta')\n  await user.click(option)\n}\n\nconst submitForm = async () => {\n  const user = userEvent.setup()\n  const submitButton = await screen.findByRole('button', { name: /save/i })\n  await user.click(submitButton)\n}\n\ndescribe('UpdateMember — SYN-205 email-collision handling', () => {\n  it('shows the collision dialog (does not navigate away) when the update returns a collision error', async () => {\n    const variables = baseUpdateVariables('taken@example.com')\n\n    renderUpdateMember([\n      memberBioMock,\n      memberChurchMock,\n      basontasMock,\n      memberBacentaSearchMock,\n      collisionUpdateMock(variables),\n      // UpdateMember's useMutation always sets refetchQueries for these two\n      // queries. Since errorPolicy: 'all' means mutate() resolves (rather\n      // than rejects) even on a collision error, Apollo still runs the\n      // refetch — so a second copy of each read is needed here too.\n      memberBioMock,\n      memberChurchMock,\n    ])\n\n    await screen.findByDisplayValue('ama@example.com')\n    await selectBacentaFromDropdown()\n\n    const emailInput = screen.getByLabelText(/email address/i)\n    await userEvent.setup().clear(emailInput)\n    await userEvent.setup().type(emailInput, 'taken@example.com')\n\n    await submitForm()\n\n    const description = await screen.findByText(\n      (_, element) =>\n        element?.getAttribute('data-slot') === 'dialog-description' &&\n        (element?.textContent ?? '').includes('already belongs to')\n    )\n    expect(description).toBeInTheDocument()\n    expect(screen.getByText(/Kofi Asante/)).toBeInTheDocument()\n\n    // The whole point of the bug: this must NOT have fired.\n    expect(mockNavigate).not.toHaveBeenCalled()\n  })\n\n  it('navigates away on a genuine successful update', async () => {\n    const variables = baseUpdateVariables('newemail@example.com')\n\n    renderUpdateMember([\n      memberBioMock,\n      memberChurchMock,\n      basontasMock,\n      memberBacentaSearchMock,\n      successUpdateMock(variables),\n      memberBioMock,\n      memberChurchMock,\n    ])\n\n    await screen.findByDisplayValue('ama@example.com')\n    await selectBacentaFromDropdown()\n\n    const emailInput = screen.getByLabelText(/email address/i)\n    await userEvent.setup().clear(emailInput)\n    await userEvent.setup().type(emailInput, 'newemail@example.com')\n\n    await submitForm()\n\n    await waitFor(() =>\n      expect(mockNavigate).toHaveBeenCalledWith('/member/displaydetails')\n    )\n  })\n})\n","numLines":360,"startLine":1,"totalLines":360}}}
