{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G63HrqYyEehP7XH9gFyg8W","type":"tool_result","content":"1\t/**\n2\t * createApolloClient — SYN-79\n3\t *\n4\t * Builds the ApolloClient used by the admin portal. Extracted from src/index.tsx\n5\t * so the link chain (retry → error → auth → http) can be unit-tested with MSW\n6\t * without having to mount the full React app + AuthProvider.\n7\t *\n8\t * Behaviour-preserving: every link, every option, every constant matches the\n9\t * inline construction that previously lived in AppWithApollo. The only change\n10\t * is the seam — index.tsx now calls this factory.\n11\t *\n12\t * The factory takes a `getAccessTokenSilently` resolver so callers can supply\n13\t * either the real AuthContext token getter or a test stub. Apollo links read\n14\t * the token per-request through this closure, so token rotation (refresh,\n15\t * logout) is reflected on the next outgoing request without rebuilding the\n16\t * client.\n17\t */\n18\t\n19\timport { RetryLink } from '@apollo/client/link/retry'\n20\timport { onError } from '@apollo/client/link/error'\n21\timport {\n22\t  ApolloClient,\n23\t  NormalizedCacheObject,\n24\t  ServerError,\n25\t  ServerParseError,\n26\t  createHttpLink,\n27\t  from,\n28\t} from '@apollo/client'\n29\timport { setContext } from '@apollo/client/link/context'\n30\timport { toast } from 'sonner'\n31\timport buildApolloCache from 'lib/apollo-cache'\n32\t\n33\texport const AUTH_LINK_TOKEN_TIMEOUT_MS = 8000\n34\t\n35\texport const RETRY_LINK_MAX_ATTEMPTS = 5\n36\t\n37\texport interface CreateApolloClientOptions {\n38\t  /**\n39\t   * Resolver for the per-request access token. Returns the raw JWT, or rejects\n40\t   * if no valid token is available (in which case the request goes out with\n41\t   * no Authorization header and the server rejects it).\n42\t   */\n43\t  getAccessTokenSilently: () => Promise<string>\n44\t  /**\n45\t   * Override the GraphQL endpoint. Defaults to VITE_SYNAGO_GRAPHQL_URI or\n46\t   * `http://localhost:4001/graphql`. Tests pass an MSW-intercepted URL here.\n47\t   */\n48\t  uri?: string\n49\t}\n50\t\n51\tconst defaultUri = (): string =>\n52\t  import.meta.env.VITE_SYNAGO_GRAPHQL_URI || 'http://localhost:4001/graphql'\n53\t\n54\texport function createApolloClient({\n55\t  getAccessTokenSilently,\n56\t  uri,\n57\t}: CreateApolloClientOptions): ApolloClient<NormalizedCacheObject> {\n58\t  const resolvedUri = uri ?? defaultUri()\n59\t\n60\t  const httpLink = createHttpLink({ uri: resolvedUri })\n61\t\n62\t  const authLink = setContext(async (_, { headers }) => {\n63\t    // Pull a fresh token per-request. getAccessTokenSilently transparently\n64\t    // refreshes via the refresh token when the access token is past the\n65\t    // local expiry buffer, so outgoing queries never ship a stale Bearer.\n66\t    // Race against a timeout so a hung refresh fetch can't block every\n67\t    // in-flight request indefinitely — RetryLink only retries failures, not\n68\t    // requests stalled in the link layer.\n69\t    let token = ''\n70\t    let timerId: ReturnType<typeof setTimeout> | undefined\n71\t    try {\n72\t      token = await Promise.race([\n73\t        getAccessTokenSilently(),\n74\t        new Promise<string>((_resolve, reject) => {\n75\t          timerId = setTimeout(\n76\t            () => reject(new Error('Auth token fetch timed out')),\n77\t            AUTH_LINK_TOKEN_TIMEOUT_MS\n78\t          )\n79\t        }),\n80\t      ])\n81\t    } catch {\n82\t      // No token / refresh failed / timed out. If refresh failed for real,\n83\t      // AuthContext has already cleared the user and SimpleApp will swap to\n84\t      // the login screen; if it timed out, the request goes without auth and\n85\t      // the server will reject it.\n86\t    } finally {\n87\t      if (timerId !== undefined) clearTimeout(timerId)\n88\t    }\n89\t\n90\t    return {\n91\t      headers: {\n92\t        ...headers,\n93\t        ...(token ? { Authorization: `Bearer ${token}` } : {}),\n94\t      },\n95\t    }\n96\t  })\n97\t\n98\t  const retryLink = new RetryLink({\n99\t    delay: {\n100\t      initial: 300,\n101\t      max: 2000,\n102\t      jitter: true,\n103\t    },\n104\t    attempts: {\n105\t      max: RETRY_LINK_MAX_ATTEMPTS,\n106\t      // 4xx responses are client errors — auth / permission / validation.\n107\t      // Looping them is harmful (token-expiry storms, lock-out cascades), so\n108\t      // only retry on transport failures (no statusCode) and 5xx responses.\n109\t      // HttpLink rejects with ServerError or ServerParseError on HTTP-status\n110\t      // failures (both carry statusCode); transport failures (DNS, abort,\n111\t      // network drop) reject with a plain Error with no statusCode.\n112\t      retryIf: (\n113\t        error: ServerError | ServerParseError | Error | undefined\n114\t      ): boolean => {\n115\t        if (!error) return false\n116\t        if (!('statusCode' in error)) return true\n117\t        return error.statusCode >= 500\n118\t      },\n119\t    },\n120\t  })\n121\t\n122\t  const errorLink = onError(({ graphQLErrors, networkError }) => {\n123\t    // SYN-178 — never render raw GraphQL/network internals (message, locations,\n124\t    // path, Neo4j error text) into a user-facing toast. Show a generic message;\n125\t    // the technical detail only reaches the dev console (compiled out of the\n126\t    // production bundle via import.meta.env.DEV).\n127\t    if (graphQLErrors) {\n128\t      graphQLErrors.forEach(({ message, locations, path }) => {\n129\t        if (message.includes('Unauthenticated')) return\n130\t\n131\t        if (import.meta.env.DEV) {\n132\t          // eslint-disable-next-line no-console\n133\t          console.error(\n134\t            `[GraphQL error]: ${message}`,\n135\t            locations ? { locations, path } : { path }\n136\t          )\n137\t        }\n138\t\n139\t        toast.error('Something went wrong', {\n140\t          id: `gql:${message}:${path?.join('.') ?? ''}`,\n141\t          description: 'Please try again. If this keeps happening, contact support.',\n142\t          duration: 8000,\n143\t        })\n144\t      })\n145\t    }\n146\t\n147\t    if (\n148\t      networkError &&\n149\t      !networkError.message.includes('400') &&\n150\t      !networkError.message.includes('Failed to fetch')\n151\t    ) {\n152\t      if (import.meta.env.DEV) {\n153\t        // eslint-disable-next-line no-console\n154\t        console.error(`[Network error]: ${networkError.message}`)\n155\t      }\n156\t\n157\t      toast.error('Network Error', {\n158\t        id: `network:${networkError.message}`,\n159\t        description:\n160\t          'We could not reach the server. Check your connection and try again.',\n161\t        duration: 8000,\n162\t      })\n163\t    }\n164\t  })\n165\t\n166\t  const errorPolicy = 'all'\n167\t\n168\t  // Link order matters. errorLink sits OUTSIDE the retry boundary so a\n169\t  // GraphQL or network error surfaces a toast exactly once per query —\n170\t  // regardless of how many attempts retryLink burned underneath. The retry\n171\t  // boundary then wraps authLink + httpLink so each attempt picks up a fresh\n172\t  // Authorization header (token rotation between attempts is supported).\n173\t  return new ApolloClient({\n174\t    uri: resolvedUri,\n175\t    link: from([errorLink, retryLink, authLink.concat(httpLink)]),\n176\t    cache: buildApolloCache(),\n177\t    connectToDevTools: true,\n178\t    defaultOptions: {\n179\t      watchQuery: {\n180\t        errorPolicy,\n181\t      },\n182\t      query: {\n183\t        errorPolicy,\n184\t      },\n185\t      mutate: {\n186\t        errorPolicy,\n187\t      },\n188\t    },\n189\t  })\n190\t}\n191\t"}]},"parent_tool_use_id":"toolu_019VwmAe8cPjMy8hT6rWpJsH","session_id":"1f8dd599-a4b3-4691-9eeb-51a7fceb4862","uuid":"85e5d38f-2e65-42b5-919d-10a502b3b945","timestamp":"2026-07-15T02:07:30.875Z","subagent_type":"code-reviewer","task_description":"Code review of SYN-205 email update fix"}
