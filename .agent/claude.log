rong\\\" toast and navigates away to the profile view as if the save succeeded, while the email is unchanged.\",\n      \"alt\": \"Member profile page showing a generic 'Something went wrong' error toast after a failed email update, with the email still unchanged\"\n    },\n    {\n      \"file\": \"before-mobile.png\",\n      \"frame\": \"mobile\",\n      \"width\": 390,\n      \"height\": 844,\n      \"tag\": \"before\",\n      \"label\": \"MEMBER PROFILE\",\n      \"caption\": \"Submitting a duplicate email on Council Leader Tester's profile silently fails: the app shows a generic \\\"Something went wrong\\\" toast and navigates away to the profile view as if the save succeeded, while the email is unchanged.\",\n      \"alt\": \"Member profile page showing a generic 'Something went wrong' error toast after a failed email update, with the email still unchanged\"\n    },\n    {\n      \"file\": \"after-desktop.png\",\n      \"frame\": \"desktop\",\n      \"width\": 1440,\n      \"height\": 900,\n      \"tag\": \"after\",\n      \"label\": \"EDIT MEMBER\",\n      \"caption\": \"With the fix applied, submitting the same duplicate email now shows the specific \\\"Member already registered\\\" collision dialog and keeps the user on the edit form instead of silently discarding the update.\",\n      \"alt\": \"Edit Member form with a 'Member already registered' collision dialog explaining the email already belongs to another member\"\n    },\n    {\n      \"file\": \"after-tablet.png\",\n      \"frame\": \"tablet\",\n      \"width\": 820,\n      \"height\": 1180,\n      \"tag\": \"after\",\n      \"label\": \"EDIT MEMBER\",\n      \"caption\": \"With the fix applied, submitting the same duplicate email now shows the specific \\\"Member already registered\\\" collision dialog and keeps the user on the edit form instead of silently discarding the update.\",\n      \"alt\": \"Edit Member form with a 'Member already registered' collision dialog explaining the email already belongs to another member\"\n    },\n    {\n      \"file\": \"after-mobile.png\",\n      \"frame\": \"mobile\",\n      \"width\": 390,\n      \"height\": 844,\n      \"tag\": \"after\",\n      \"label\": \"EDIT MEMBER\",\n      \"caption\": \"With the fix applied, submitting the same duplicate email now shows the specific \\\"Member already registered\\\" collision dialog and keeps the user on the edit form instead of silently discarding the update.\",\n      \"alt\": \"Edit Member form with a 'Member already registered' collision dialog explaining the email already belongs to another member\"\n    },\n    {\n      \"file\": \"verify-desktop.png\",\n      \"frame\": \"desktop\",\n      \"width\": 1440,\n      \"height\": 900,\n      \"tag\": \"verify\",\n      \"label\": \"MEMBER PROFILE\",\n      \"caption\": \"Submitting a genuinely unique email address saves successfully: the app navigates to the profile page and shows the updated email address, with a matching \\\"Details were updated\\\" history entry.\",\n      \"alt\": \"Member profile page showing the newly saved, updated email address after a successful update\"\n    },\n    {\n      \"file\": \"verify-tablet.png\",\n      \"frame\": \"tablet\",\n      \"width\": 820,\n      \"height\": 1180,\n      \"tag\": \"verify\",\n      \"label\": \"MEMBER PROFILE\",\n      \"caption\": \"Submitting a genuinely unique email address saves successfully: the app navigates to the profile page and shows the updated email address, with a matching \\\"Details were updated\\\" history entry.\",\n      \"alt\": \"Member profile page showing the newly saved, updated email address after a successful update\"\n    },\n    {\n      \"file\": \"verify-mobile.png\",\n      \"frame\": \"mobile\",\n      \"width\": 390,\n      \"height\": 844,\n      \"tag\": \"verify\",\n      \"label\": \"MEMBER PROFILE\",\n      \"caption\": \"Submitting a genuinely unique email address saves successfully: the app navigates to the profile page and shows the updated email address, with a matching \\\"Details were updated\\\" history entry.\",\n      \"alt\": \"Member profile page showing the newly saved, updated email address after a successful update\"\n    }\n  ],\n  \"followUps\": [\n    \"CreateMember.tsx and the self-profile EditPage.tsx share the same errorPolicy: 'all' unguarded-mutation-result pattern this ticket fixed in UpdateMember.tsx — worth applying the identical fix there.\",\n    \"api/src/resolvers/directory/directory-resolvers.ts's UpdateMemberDetails resolver is missing an assertScopeViaMember(context, args.id) check (unlike its siblings UpdateMemberBacenta/ReactivateMemberToBacenta in the same file) — a Bacenta-level leader/admin can currently edit any member's profile org-wide by ID. Pre-existing, unrelated to this fix, but a real IDOR worth its own ticket.\",\n    \"The global errorLink in lib/createApolloClient.tsx toasts a generic \\\"Something went wrong\\\" for every GraphQL error, including ones already given better UX by a caller (e.g. the collision dialog here) — so collisions now show both the friendly dialog and a redundant generic toast. Consider skipping the generic toast when extensions.collision (or a BAD_USER_INPUT-style code) is present.\"\n  ]\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":937,"cache_read_input_tokens":320666,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":937},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"1f8dd599-a4b3-4691-9eeb-51a7fceb4862","uuid":"1409c9b6-c58c-4817-8434-67846867dae6","request_id":"req_011Cd34vutTp2H5YMKt8fgE2"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QifUWkx4QpfzWHBt7w8Zmq","type":"tool_result","content":"The file /home/ubuntu/.openclaw/workspace/repos/fl-admin-portal/.agent/report.json has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"1f8dd599-a4b3-4691-9eeb-51a7fceb4862","uuid":"af1d814c-f72f-411e-af8d-0cc799b4702c","timestamp":"2026-07-15T02:39:36.719Z","tool_use_result":{"type":"update","filePath":"/home/ubuntu/.openclaw/workspace/repos/fl-admin-portal/.agent/report.json","content":"{\n  \"type\": \"bug\",\n  \"labels\": [\"client-reported\", \"email\", \"form-submission\", \"member-profile\"],\n  \"title\": \"Fix member profile email updates silently failing under errorPolicy: 'all'\",\n  \"bug\": \"Apollo Client is configured with `errorPolicy: 'all'` (SYN-178), so GraphQL errors from `UpdateMemberDetails` (e.g. the server-side email/WhatsApp collision check) land on `result.errors` instead of rejecting the mutation promise. `UpdateMember.tsx`'s `onSubmit` only had a try/catch around the mutation call, which never fired, so a rejected write (most commonly a duplicate-email collision) was silently treated as a success: the form ran its follow-up bacenta/basonta mutations, reset, and navigated away as if the profile had saved — while nothing was actually written. A separate global error handler then fired an unrelated generic \\\"Something went wrong\\\" toast, matching the exact symptom reported.\",\n  \"summary\": \"`onSubmit` in `UpdateMember.tsx` now captures the mutation result and explicitly checks `updateResult.errors`. A real email/WhatsApp collision routes to the existing **MemberCollisionDialog** (the same UX it should always have had); any other GraphQL error calls `displayError` and the function returns *before* the follow-up bacenta/basonta mutations or navigation run, so a rejected write can no longer masquerade as a success. Applied the same `.errors` guard to the `UpdateMemberBacenta` and `UpdateMemberBasonta` follow-up calls in the same function, which had the identical unguarded-error gap. Extracted a typed `extractCollision()` helper (no `any`) shared by both the new `result.errors` path and the pre-existing `catch` block's `graphQLErrors` path. Fixed `getGraphQLErrorMessage` in `errorHandler.ts` to read `.message` off plain `GraphQLFormattedError`-shaped objects (not just `Error`/`ApolloError` instances), so a non-collision error surfaces its real message instead of `\\\"[object Object]\\\"`.\",\n  \"evidenceNote\": \"Reproduced the exact bug from the attached screenshot (generic \\\"Something went wrong\\\" toast, no data saved) by editing a member's email to one already used by another member in the same bacenta, against the live dev database. Screenshots below were captured by temporarily reverting the fix in the working tree to force the original code path for the 'before' shots, then restoring it for 'after'/'verify' — all three states were driven through the real dev GraphQL API, not mocks.\",\n  \"checks\": [\n    { \"label\": \"tsc\", \"pass\": true },\n    { \"label\": \"eslint\", \"pass\": true },\n    { \"label\": \"Build\", \"pass\": true },\n    { \"label\": \"Tests (308/308, 20 files)\", \"pass\": true }\n  ],\n  \"shots\": [\n    {\n      \"file\": \"before-desktop.png\",\n      \"frame\": \"desktop\",\n      \"width\": 1440,\n      \"height\": 900,\n      \"tag\": \"before\",\n      \"label\": \"MEMBER PROFILE\",\n      \"caption\": \"Submitting a duplicate email on Council Leader Tester's profile silently fails: the app shows a generic \\\"Something went wrong\\\" toast and navigates away to the profile view as if the save succeeded, while the email is unchanged.\",\n      \"alt\": \"Member profile page showing a generic 'Something went wrong' error toast after a failed email update, with the email still unchanged\"\n    },\n    {\n      \"file\": \"before-tablet.png\",\n      \"frame\": \"tablet\",\n      \"width\": 820,\n      \"height\": 1180,\n      \"tag\": \"before\",\n      \"label\": \"MEMBER PROFILE\",\n      \"caption\": \"Submitting a duplicate email on Council Leader Tester's profile silently fails: the app shows a generic \\\"Something went wrong\\\" toast and navigates away to the profile view as if the save succeeded, while the email is unchanged.\",\n      \"alt\": \"Member profile page showing a generic 'Something went wrong' error toast after a failed email update, with the email still unchanged\"\n    },\n    {\n      \"file\": \"before-mobile.png\",\n      \"frame\": \"mobile\",\n      \"width\": 390,\n      \"height\": 844,\n      \"tag\": \"before\",\n      \"label\": \"MEMBER PROFILE\",\n      \"caption\": \"Submitting a duplicate email on Council Leader Tester's profile silently fails: the app shows a generic \\\"Something went wrong\\\" toast and navigates away to the profile view as if the save succeeded, while the email is unchanged.\",\n      \"alt\": \"Member profile page showing a generic 'Something went wrong' error toast after a failed email update, with the email still unchanged\"\n    },\n    {\n      \"file\": \"after-desktop.png\",\n      \"frame\": \"desktop\",\n      \"width\": 1440,\n      \"height\": 900,\n      \"tag\": \"after\",\n      \"label\": \"EDIT MEMBER\",\n      \"caption\": \"With the fix applied, submitting the same duplicate email now shows the specific \\\"Member already registered\\\" collision dialog and keeps the user on the edit form instead of silently discarding the update.\",\n      \"alt\": \"Edit Member form with a 'Member already registered' collision dialog explaining the email already belongs to another member\"\n    },\n    {\n      \"file\": \"after-tablet.png\",\n      \"frame\": \"tablet\",\n      \"width\": 820,\n      \"height\": 1180,\n      \"tag\": \"after\",\n      \"label\": \"EDIT MEMBER\",\n      \"caption\": \"With the fix applied, submitting the same duplicate email now shows the specific \\\"Member already registered\\\" collision dialog and keeps the user on the edit form instead of silently discarding the update.\",\n      \"alt\": \"Edit Member form with a 'Member already registered' collision dialog explaining the email already belongs to another member\"\n    },\n    {\n      \"file\": \"after-mobile.png\",\n      \"frame\": \"mobile\",\n      \"width\": 390,\n      \"height\": 844,\n      \"tag\": \"after\",\n      \"label\": \"EDIT MEMBER\",\n      \"caption\": \"With the fix applied, submitting the same duplicate email now shows the specific \\\"Member already registered\\\" collision dialog and keeps the user on the edit form instead of silently discarding the update.\",\n      \"alt\": \"Edit Member form with a 'Member already registered' collision dialog explaining the email already belongs to another member\"\n    },\n    {\n      \"file\": \"verify-desktop.png\",\n      \"frame\": \"desktop\",\n      \"width\": 1440,\n      \"height\": 900,\n      \"tag\": \"verify\",\n      \"label\": \"MEMBER PROFILE\",\n      \"caption\": \"Submitting a genuinely unique email address saves successfully: the app navigates to the profile page and shows the updated email address, with a matching \\\"Details were updated\\\" history entry.\",\n      \"alt\": \"Member profile page showing the newly saved, updated email address after a successful update\"\n    },\n    {\n      \"file\": \"verify-tablet.png\",\n      \"frame\": \"tablet\",\n      \"width\": 820,\n      \"height\": 1180,\n      \"tag\": \"verify\",\n      \"label\": \"MEMBER PROFILE\",\n      \"caption\": \"Submitting a genuinely unique email address saves successfully: the app navigates to the profile page and shows the updated email address, with a matching \\\"Details were updated\\\" history entry.\",\n      \"alt\": \"Member profile page showing the newly saved, updated email address after a successful update\"\n    },\n    {\n      \"file\": \"verify-mobile.png\",\n      \"frame\": \"mobile\",\n      \"width\": 390,\n      \"height\": 844,\n      \"tag\": \"verify\",\n      \"label\": \"MEMBER PROFILE\",\n      \"caption\": \"Submitting a genuinely unique email address saves successfully: the app navigates to the profile page and shows the updated email address, with a matching \\\"Details were updated\\\" history entry.\",\n      \"alt\": \"Member profile page showing the newly saved, updated email address after a successful update\"\n    }\n  ],\n  \"followUps\": [\n    \"CreateMember.tsx and the self-profile EditPage.tsx share the same errorPolicy: 'all' unguarded-mutation-result pattern this ticket fixed in UpdateMember.tsx — worth applying the identical fix there.\",\n    \"api/src/resolvers/directory/directory-resolvers.ts's UpdateMemberDetails resolver is missing an assertScopeViaMember(context, args.id) check (unlike its siblings UpdateMemberBacenta/ReactivateMemberToBacenta in the same file) — a Bacenta-level leader/admin can currently edit any member's profile org-wide by ID. Pre-existing, unrelated to this fix, but a real IDOR worth its own ticket.\",\n    \"The global errorLink in lib/createApolloClient.tsx toasts a generic \\\"Something went wrong\\\" for every GraphQL error, including ones already given better UX by a caller (e.g. the collision dialog here) — so collisions now show both the friendly dialog and a redundant generic toast. Consider skipping the generic toast when extensions.collision (or a BAD_USER_INPUT-style code) is present.\"\n  ]\n}\n","structuredPatch":[{"oldStart":1,"oldLines":19,"newStart":1,"newLines":111,"lines":[" {","-  \"type\": \"Task\",","-  \"labels\": [\"smith-followup\"],","-  \"title\": \"Delete CustomLabel.tsx — confirmed dead code\",","-  \"bug\": \"`web-react-ts/src/components/pie-chart/CustomLabel.tsx` (a recharts pie-chart label component) had zero importers anywhere in the app. It was flagged as dead code while working SYN-201 but left untouched there; it