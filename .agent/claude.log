{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GeD52a5jHkyGuaGNeoTUXR","type":"tool_result","content":"1\timport { ApolloError } from '@apollo/client'\n2\timport { toast } from 'sonner'\n3\t\n4\t/**\n5\t * Extracts the first meaningful error message from a GraphQL error\n6\t * Handles permission errors, validation errors, and other GraphQL errors\n7\t */\n8\texport const getGraphQLErrorMessage = (error: unknown): string => {\n9\t  if (!error) return 'An unknown error occurred'\n10\t\n11\t  if (error instanceof ApolloError) {\n12\t    // First, try to get the most relevant GraphQL error message\n13\t    if (error.graphQLErrors && error.graphQLErrors.length > 0) {\n14\t      // Look for permission or permission-related errors first\n15\t      const permissionError = error.graphQLErrors.find((err) =>\n16\t        err.message.toLowerCase().includes('permit')\n17\t      )\n18\t      if (permissionError) {\n19\t        return permissionError.message\n20\t      }\n21\t\n22\t      // Return the first error if no specific type found\n23\t      return error.graphQLErrors[0].message\n24\t    }\n25\t\n26\t    // Fall back to network error if no graphQL errors\n27\t    if (error.networkError) {\n28\t      return error.networkError.message\n29\t    }\n30\t  }\n31\t\n32\t  if (error instanceof Error) {\n33\t    return error.message\n34\t  }\n35\t\n36\t  return String(error)\n37\t}\n38\t\n39\t/**\n40\t * Displays an error using industry-standard snackbar notification\n41\t * This provides consistent error feedback across the application\n42\t */\n43\texport const displayError = (\n44\t  title: string,\n45\t  error: unknown,\n46\t  duration = 15000\n47\t) => {\n48\t  const errorMessage = getGraphQLErrorMessage(error)\n49\t\n50\t  toast.error(title, {\n51\t    id: `${title}:${errorMessage}`,\n52\t    description: errorMessage,\n53\t    duration,\n54\t  })\n55\t}\n56\t\n57\t/**\n58\t * Extracts all GraphQL error messages from an ApolloError\n59\t * Useful for logging or detailed error handling\n60\t */\n61\texport const getAllGraphQLErrorMessages = (error: ApolloError): string[] => {\n62\t  if (!error.graphQLErrors || error.graphQLErrors.length === 0) {\n63\t    return []\n64\t  }\n65\t  return error.graphQLErrors.map((err) => err.message)\n66\t}\n67\t\n68\t/**\n69\t * Checks if an error is a permission/authorization error\n70\t */\n71\texport const isPermissionError = (error: unknown): boolean => {\n72\t  if (error instanceof ApolloError) {\n73\t    const message = getGraphQLErrorMessage(error).toLowerCase()\n74\t    return (\n75\t      message.includes('permit') ||\n76\t      message.includes('authorized') ||\n77\t      message.includes('unauthorized')\n78\t    )\n79\t  }\n80\t  return false\n81\t}\n82\t"}]},"parent_tool_use_id":"toolu_01JoefhpidbdwCMGm8obaPNk","session_id":"1f8dd599-a4b3-4691-9eeb-51a7fceb4862","uuid":"eebf30ef-976c-4ddb-8589-b7b53a5ff6ab","timestamp":"2026-07-15T02:07:35.013Z","subagent_type":"security-reviewer","task_description":"Security review of SYN-205 email update fix"}
