{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EF3zFR5Y9HyExohAuJJkb3","type":"tool_result","content":"1\timport React, { useContext, useState } from 'react'\n2\timport { useNavigate } from 'react-router-dom'\n3\timport { useQuery, useMutation } from '@apollo/client'\n4\t\n5\timport { parsePhoneNum, throwToSentry } from 'global-utils'\n6\timport { displayError } from 'utils/errorHandler'\n7\timport {\n8\t  UPDATE_MEMBER_MUTATION,\n9\t  UPDATE_MEMBER_BACENTA,\n10\t  UPDATE_MEMBER_BASONTA,\n11\t  REACTIVATE_MEMBER_TO_BACENTA,\n12\t} from './UpdateMutations'\n13\timport {\n14\t  DISPLAY_MEMBER_BIO,\n15\t  DISPLAY_MEMBER_CHURCH,\n16\t} from '../display/ReadQueries'\n17\t\n18\timport { MemberContext } from 'contexts/MemberContext'\n19\timport MemberForm from '../reusable-forms/MemberForm'\n20\timport { CreateMemberFormOptions } from '../create/CreateMember'\n21\timport { FormikHelpers } from 'formik'\n22\timport MemberCollisionDialog, { MemberCollision } from './MemberCollisionDialog'\n23\t\n24\tconst UpdateMember = () => {\n25\t  const { memberId, setMemberId } = useContext(MemberContext)\n26\t  const [collision, setCollision] = useState<MemberCollision | null>(null)\n27\t\n28\t  const {\n29\t    data: memberData,\n30\t    error: memberError,\n31\t    loading: memberLoading,\n32\t  } = useQuery(DISPLAY_MEMBER_BIO, {\n33\t    variables: { id: memberId },\n34\t  })\n35\t  const error: any = memberError\n36\t  const { data: churchData } = useQuery(DISPLAY_MEMBER_CHURCH, {\n37\t    variables: { id: memberId },\n38\t  })\n39\t  const member = memberData?.members[0]\n40\t  const memberChurch = churchData?.members[0]\n41\t\n42\t  const initialValues: CreateMemberFormOptions = {\n43\t    firstName: member?.firstName ?? '',\n44\t    middleName: member?.middleName ?? '',\n45\t    lastName: member?.lastName ?? '',\n46\t    gender: member?.gender?.gender ?? '',\n47\t    phoneNumber: member?.phoneNumber ? `+${member?.phoneNumber}` : '',\n48\t    whatsappNumber: member?.whatsappNumber ? `+${member?.whatsappNumber}` : '',\n49\t    email: member?.email ?? '',\n50\t    dob: member?.dob ? member.dob.date : '',\n51\t    maritalStatus: member?.maritalStatus?.status ?? '',\n52\t    occupation: member?.occupation?.occupation ?? '',\n53\t    pictureUrl: member?.pictureUrl ?? '',\n54\t    visitationArea: member?.visitationArea ?? 'no-location',\n55\t    bacenta: memberChurch?.bacenta,\n56\t    basonta: memberChurch?.basonta?.id ?? '',\n57\t  }\n58\t\n59\t  const navigate = useNavigate()\n60\t\n61\t  const [UpdateMember] = useMutation(UPDATE_MEMBER_MUTATION, {\n62\t    refetchQueries: [\n63\t      { query: DISPLAY_MEMBER_BIO, variables: { id: memberId } },\n64\t      { query: DISPLAY_MEMBER_CHURCH, variables: { id: memberId } },\n65\t    ],\n66\t  })\n67\t  const [UpdateMemberBacenta] = useMutation(UPDATE_MEMBER_BACENTA)\n68\t  const [UpdateMemberBasonta] = useMutation(UPDATE_MEMBER_BASONTA)\n69\t  const [ReactivateMember, { loading: reactivating }] = useMutation(\n70\t    REACTIVATE_MEMBER_TO_BACENTA\n71\t  )\n72\t\n73\t  const onReactivate = async () => {\n74\t    if (!collision?.targetBacentaId) {\n75\t      displayError(\n76\t        'Cannot reactivate',\n77\t        new Error('Select a bacenta for this member before reactivating.')\n78\t      )\n79\t      return\n80\t    }\n81\t\n82\t    try {\n83\t      const res = await ReactivateMember({\n84\t        variables: {\n85\t          memberId: collision.memberId,\n86\t          bacentaId: collision.targetBacentaId,\n87\t        },\n88\t      })\n89\t\n90\t      const reactivatedId =\n91\t        res.data?.ReactivateMemberToBacenta?.id ?? collision.memberId\n92\t\n93\t      setCollision(null)\n94\t      setMemberId(reactivatedId)\n95\t      navigate('/member/displaydetails')\n96\t    } catch (error: unknown) {\n97\t      displayError('There was an error reactivating the member', error)\n98\t    }\n99\t  }\n100\t\n101\t  const onSubmit = async (\n102\t    values: CreateMemberFormOptions,\n103\t    onSubmitProps: FormikHelpers<CreateMemberFormOptions>\n104\t  ) => {\n105\t    onSubmitProps.setSubmitting(true)\n106\t\n107\t    try {\n108\t      await UpdateMember({\n109\t        variables: {\n110\t          id: memberId,\n111\t          firstName: values.firstName.trim(),\n112\t          middleName: values.middleName.trim(),\n113\t          lastName: values.lastName.trim(),\n114\t          email: values.email?.trim().toLowerCase() || null,\n115\t          gender: values.gender,\n116\t          phoneNumber: parsePhoneNum(values.phoneNumber),\n117\t          whatsappNumber: parsePhoneNum(values.whatsappNumber),\n118\t          dob: values.dob,\n119\t          maritalStatus: values.maritalStatus,\n120\t          occupation: values.occupation,\n121\t          pictureUrl: values.pictureUrl,\n122\t\n123\t          bacenta: values.bacenta?.id,\n124\t        },\n125\t      })\n126\t\n127\t      if (memberChurch?.bacenta.id !== values.bacenta.id) {\n128\t        await UpdateMemberBacenta({\n129\t          variables: {\n130\t            memberId: memberId,\n131\t            bacentaId: values.bacenta?.id,\n132\t            ids: [memberId, values.bacenta?.id, memberChurch?.bacenta.id],\n133\t            historyRecord: `${member.firstName} ${member.lastName} moved from ${memberChurch?.bacenta.name} Bacenta to ${values.bacenta?.name} Bacenta`,\n134\t          },\n135\t        })\n136\t      }\n137\t\n138\t      if (values.basonta && memberChurch?.basonta?.id !== values.basonta) {\n139\t        await UpdateMemberBasonta({\n140\t          variables: {\n141\t            memberId: memberId,\n142\t            basontaId: values.basonta,\n143\t          },\n144\t        })\n145\t      }\n146\t\n147\t      onSubmitProps.setSubmitting(false)\n148\t      onSubmitProps.resetForm()\n149\t      navigate('/member/displaydetails')\n150\t    } catch (error: any) {\n151\t      onSubmitProps.setSubmitting(false)\n152\t\n153\t      const collisionInfo = error?.graphQLErrors?.find(\n154\t        (err: any) => err?.extensions?.collision\n155\t      )?.extensions?.collision as MemberCollision | undefined\n156\t\n157\t      if (collisionInfo) {\n158\t        setCollision({ ...collisionInfo, targetBacentaId: values.bacenta?.id })\n159\t        return\n160\t      }\n161\t\n162\t      throwToSentry('There was an error updating the member profile\\n', error)\n163\t    }\n164\t  }\n165\t\n166\t  if (error) {\n167\t    throwToSentry(error)\n168\t  }\n169\t\n170\t  return (\n171\t    <>\n172\t      <MemberForm\n173\t        initialValues={initialValues}\n174\t        onSubmit={onSubmit}\n175\t        loading={memberLoading}\n176\t        update\n177\t      />\n178\t      <MemberCollisionDialog\n179\t        collision={collision}\n180\t        reactivating={reactivating}\n181\t        onReactivate={onReactivate}\n182\t        onClose={() => setCollision(null)}\n183\t      />\n184\t    </>\n185\t  )\n186\t}\n187\t\n188\texport default UpdateMember\n189\t"}]},"parent_tool_use_id":null,"session_id":"1f8dd599-a4b3-4691-9eeb-51a7fceb4862","uuid":"5860d502-6671-48ce-9f74-481f72e31d4c","timestamp":"2026-07-15T02:02:34.213Z","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/.openclaw/workspace/repos/fl-admin-portal/web-react-ts/src/pages/directory/update/UpdateMember.tsx","content":"import React, { useContext, useState } from 'react'\nimport { useNavigate } from 'react-router-dom'\nimport { useQuery, useMutation } from '@apollo/client'\n\nimport { parsePhoneNum, throwToSentry } from 'global-utils'\nimport { displayError } from 'utils/errorHandler'\nimport {\n  UPDATE_MEMBER_MUTATION,\n  UPDATE_MEMBER_BACENTA,\n  UPDATE_MEMBER_BASONTA,\n  REACTIVATE_MEMBER_TO_BACENTA,\n} from './UpdateMutations'\nimport {\n  DISPLAY_MEMBER_BIO,\n  DISPLAY_MEMBER_CHURCH,\n} from '../display/ReadQueries'\n\nimport { MemberContext } from 'contexts/MemberContext'\nimport MemberForm from '../reusable-forms/MemberForm'\nimport { CreateMemberFormOptions } from '../create/CreateMember'\nimport { FormikHelpers } from 'formik'\nimport MemberCollisionDialog, { MemberCollision } from './MemberCollisionDialog'\n\nconst UpdateMember = () => {\n  const { memberId, setMemberId } = useContext(MemberContext)\n  const [collision, setCollision] = useState<MemberCollision | null>(null)\n\n  const {\n    data: memberData,\n    error: memberError,\n    loading: memberLoading,\n  } = useQuery(DISPLAY_MEMBER_BIO, {\n    variables: { id: memberId },\n  })\n  const error: any = memberError\n  const { data: churchData } = useQuery(DISPLAY_MEMBER_CHURCH, {\n    variables: { id: memberId },\n  })\n  const member = memberData?.members[0]\n  const memberChurch = churchData?.members[0]\n\n  const initialValues: CreateMemberFormOptions = {\n    firstName: member?.firstName ?? '',\n    middleName: member?.middleName ?? '',\n    lastName: member?.lastName ?? '',\n    gender: member?.gender?.gender ?? '',\n    phoneNumber: member?.phoneNumber ? `+${member?.phoneNumber}` : '',\n    whatsappNumber: member?.whatsappNumber ? `+${member?.whatsappNumber}` : '',\n    email: member?.email ?? '',\n    dob: member?.dob ? member.dob.date : '',\n    maritalStatus: member?.maritalStatus?.status ?? '',\n    occupation: member?.occupation?.occupation ?? '',\n    pictureUrl: member?.pictureUrl ?? '',\n    visitationArea: member?.visitationArea ?? 'no-location',\n    bacenta: memberChurch?.bacenta,\n    basonta: memberChurch?.basonta?.id ?? '',\n  }\n\n  const navigate = useNavigate()\n\n  const [UpdateMember] = useMutation(UPDATE_MEMBER_MUTATION, {\n    refetchQueries: [\n      { query: DISPLAY_MEMBER_BIO, variables: { id: memberId } },\n      { query: DISPLAY_MEMBER_CHURCH, variables: { id: memberId } },\n    ],\n  })\n  const [UpdateMemberBacenta] = useMutation(UPDATE_MEMBER_BACENTA)\n  const [UpdateMemberBasonta] = useMutation(UPDATE_MEMBER_BASONTA)\n  const [ReactivateMember, { loading: reactivating }] = useMutation(\n    REACTIVATE_MEMBER_TO_BACENTA\n  )\n\n  const onReactivate = async () => {\n    if (!collision?.targetBacentaId) {\n      displayError(\n        'Cannot reactivate',\n        new Error('Select a bacenta for this member before reactivating.')\n      )\n      return\n    }\n\n    try {\n      const res = await ReactivateMember({\n        variables: {\n          memberId: collision.memberId,\n          bacentaId: collision.targetBacentaId,\n        },\n      })\n\n      const reactivatedId =\n        res.data?.ReactivateMemberToBacenta?.id ?? collision.memberId\n\n      setCollision(null)\n      setMemberId(reactivatedId)\n      navigate('/member/displaydetails')\n    } catch (error: unknown) {\n      displayError('There was an error reactivating the member', error)\n    }\n  }\n\n  const onSubmit = async (\n    values: CreateMemberFormOptions,\n    onSubmitProps: FormikHelpers<CreateMemberFormOptions>\n  ) => {\n    onSubmitProps.setSubmitting(true)\n\n    try {\n      await UpdateMember({\n        variables: {\n          id: memberId,\n          firstName: values.firstName.trim(),\n          middleName: values.middleName.trim(),\n          lastName: values.lastName.trim(),\n          email: values.email?.trim().toLowerCase() || null,\n          gender: values.gender,\n          phoneNumber: parsePhoneNum(values.phoneNumber),\n          whatsappNumber: parsePhoneNum(values.whatsappNumber),\n          dob: values.dob,\n          maritalStatus: values.maritalStatus,\n          occupation: values.occupation,\n          pictureUrl: values.pictureUrl,\n\n          bacenta: values.bacenta?.id,\n        },\n      })\n\n      if (memberChurch?.bacenta.id !== values.bacenta.id) {\n        await UpdateMemberBacenta({\n          variables: {\n            memberId: memberId,\n            bacentaId: values.bacenta?.id,\n            ids: [memberId, values.bacenta?.id, memberChurch?.bacenta.id],\n            historyRecord: `${member.firstName} ${member.lastName} moved from ${memberChurch?.bacenta.name} Bacenta to ${values.bacenta?.name} Bacenta`,\n          },\n        })\n      }\n\n      if (values.basonta && memberChurch?.basonta?.id !== values.basonta) {\n        await UpdateMemberBasonta({\n          variables: {\n            memberId: memberId,\n            basontaId: values.basonta,\n          },\n        })\n      }\n\n      onSubmitProps.setSubmitting(false)\n      onSubmitProps.resetForm()\n      navigate('/member/displaydetails')\n    } catch (error: any) {\n      onSubmitProps.setSubmitting(false)\n\n      const collisionInfo = error?.graphQLErrors?.find(\n        (err: any) => err?.extensions?.collision\n      )?.extensions?.collision as MemberCollision | undefined\n\n      if (collisionInfo) {\n        setCollision({ ...collisionInfo, targetBacentaId: values.bacenta?.id })\n        return\n      }\n\n      throwToSentry('There was an error updating the member profile\\n', error)\n    }\n  }\n\n  if (error) {\n    throwToSentry(error)\n  }\n\n  return (\n    <>\n      <MemberForm\n        initialValues={initialValues}\n        onSubmit={onSubmit}\n        loading={memberLoading}\n        update\n      />\n      <MemberCollisionDialog\n        collision={collision}\n        reactivating={reactivating}\n        onReactivate={onReactivate}\n        onClose={() => setCollision(null)}\n      />\n    </>\n  )\n}\n\nexport default UpdateMember\n","numLines":189,"startLine":1,"totalLines":189}}}
