{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DHS9JBXMpL7qE5abfrpxBY","type":"tool_result","content":"100\t  if (axiosLike?.response?.statusText) {\n101\t    return `${axiosLike.response.status} ${axiosLike.response.statusText}`\n102\t  }\n103\t  // Neo4j driver / generic Error — use the message only. Stack frames,\n104\t  // .cause, .errors arrays, and bound parameters stay out of the log.\n105\t  if (error instanceof Error) return error.message\n106\t  // Unknown shape — record the type, not the contents.\n107\t  return `Unknown error of type ${typeof error}`\n108\t}\n109\t\n110\texport const throwToSentry = (\n111\t  message: string,\n112\t  error: ErrorCustom | string | any\n113\t) => {\n114\t  const errorSummary = summariseError(error)\n115\t  // eslint-disable-next-line no-console\n116\t  console.error(`${message}: ${errorSummary}`)\n117\t  throw new Error(`${message}: ${errorSummary}`)\n118\t}\n119\t\n120\texport const noEmptyArgsValidation = (args: any[]) => {\n121\t  if (!args.length) {\n122\t    throwToSentry(\n123\t      'Argument not in Array',\n124\t      Error('Args must be passed in array')\n125\t    )\n126\t  }\n127\t\n128\t  args.forEach((argument, index) => {\n129\t    if (!argument) {\n130\t      throwToSentry(\n131\t        'No Empty Arguments Allowed',\n132\t        Error(`${args[index - 1]} Argument Cannot Be Empty`)\n133\t      )\n134\t    }\n135\t  })\n136\t}\n137\t\n138\texport const errorHandling = (member: Member) => {\n139\t  if (!member.email) {\n140\t    throw new Error(\n141\t      `${member.firstName} ${member.lastName} does not have a valid email address. Please add an email address and then try again`\n142\t    )\n143\t  }\n144\t}\n145\t\n146\t// eslint-disable-next-line @typescript-eslint/no-explicit-any\n147\texport const rearrangeCypherObject = (\n148\t  response: QueryResult,\n149\t  horizontal?: boolean"}]},"parent_tool_use_id":"toolu_01JoefhpidbdwCMGm8obaPNk","session_id":"1f8dd599-a4b3-4691-9eeb-5