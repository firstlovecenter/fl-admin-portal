{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HFa7HEjZrNHfZNpBf4Fnos","type":"tool_result","content":"1\t/**\n2\t * UpdateMember.test.tsx — SYN-205\n3\t *\n4\t * Bug: submitting an email-address change on a member's profile silently\n5\t * \"succeeded\" client-side (form closed, navigated away) even when the\n6\t * backend rejected the write for a duplicate email/whatsapp collision.\n7\t *\n8\t * Root cause: the Apollo Client used by this app is configured with\n9\t * `errorPolicy: 'all'` (see createApolloClient.tsx, SYN-178) so that GraphQL\n10\t * errors are attached to `result.errors` instead of rejecting the mutation\n11\t * promise. `onSubmit` only had a `try/catch` around `await UpdateMember(...)`\n12\t * to detect the collision and route to <MemberCollisionDialog>. Since the\n13\t * promise never rejected, that catch block never ran — the code fell\n14\t * straight through to the \"success\" path (bacenta/basonta follow-up\n15\t * mutations, resetForm, navigate away) while nothing had actually been\n16\t * saved.\n17\t *\n18\t * Fix: `onSubmit` now inspects `updateResult.errors` explicitly. A\n19\t * collision routes to <MemberCollisionDialog> exactly like the (still\n20\t * present, now effectively a fallback) catch block did before; a\n21\t * non-collision GraphQL error surfaces a toast via displayError and stops\n22\t * before the follow-up mutations/navigation run.\n23\t *\n24\t * These tests render the real <UpdateMember /> against a MockedProvider\n25\t * with `errorPolicy: 'all'` on the mutate default (matching prod config)\n26\t * so they fail against the pre-fix code and pass against the fix.\n27\t */\n28\t\n29\timport React from 'react'\n30\timport { describe, it, expect, vi, afterEach, beforeAll } from 'vitest'\n31\timport { render, screen, waitFor, cleanup } from '@testing-library/react'\n32\timport userEvent from '@testing-library/user-event'\n33\timport { MemoryRouter } from 'react-router-dom'\n34\timport { MockedProvider, MockedResponse } from '@apollo/client/testing'\n35\timport { toast } from 'sonner'\n36\t\n37\timport UpdateMember from './UpdateMember'\n38\timport { UPDATE_MEMBER_MUTATION } from './UpdateMutations'\n39\timport {\n40\t  DISPLAY_MEMBER_BIO,\n41\t  DISPLAY_MEMBER_CHURCH,\n42\t} from '../display/ReadQueries'\n43\timport { GET_CAMPUS_BASONTAS } from 'queries/ListQueries'\n44\timport { MEMBER_BACENTA_SEARCH } from 'components/formik/SearchBacentaQueries'\n45\timport { MemberContext } from 'contexts/MemberContext'\n46\timport { ChurchContext } from 'contexts/ChurchContext'\n47\t\n48\t// Mock sonner so displayError's toast.error calls land on a spy, matching\n49\t// the pattern in lib/createApolloClient.test.tsx. vi.mock is hoisted above\n50\t// all imports, so import order above doesn't matter.\n51\tvi.mock('sonner', () => ({\n52\t  toast: {\n53\t    error: vi.fn(),\n54\t    success: vi.fn(),\n55\t    message: vi.fn(),\n56\t  },\n57\t}))\n58\t\n59\tvi.mock('react-router-dom', async () => {\n60\t  const actual =\n61\t    await vi.importActual<typeof import('react-router-dom')>('react-router-dom')\n62\t  return {\n63\t    ...actual,\n64\t    useNavigate: () => mockNavigate,\n65\t  }\n66\t})\n67\t\n68\t// RoleView (rendered by MemberForm for the Add Title / Delete buttons) →\n69\t// useAuth (auth/useAuth) → useAuth (contexts/AuthContext). Mock the context\n70\t// so isAuthorised gates purely on currentUser.roles, matching the\n71\t// ServicesMenu.test.tsx pattern elsewhere in this repo.\n72\tvi.mock('contexts/AuthContext', () => ({\n73\t  useAuth: vi.fn(() => ({ isAuthenticated: true })),\n74\t}))\n75\t\n76\tconst mockNavigate = vi.fn()\n77\t\n78\t// jsdom has no ResizeObserver; the cmdk-powered bacenta search combobox\n79\t// (SearchCombobox / SearchBacenta) requires one to mount.\n80\tbeforeAll(() => {\n81\t  class ResizeObserverStub {\n82\t    observe() {}\n83\t    unobserve() {}\n84\t    disconnect() {}\n85\t  }\n86\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n87\t  ;(globalThis as any).ResizeObserver = ResizeObserverStub\n88\t})\n89\t\n90\tafterEach(() => {\n91\t  cleanup()\n92\t  mockNavigate.mockClear()\n93\t  vi.mocked(toast.error).mockClear()\n94\t})\n95\t\n96\tconst MEMBER_ID = 'member-1'\n97\tconst BACENTA_ID = 'bacenta-1'\n98\tconst CAMPUS_ID = 'campus-1'\n99\t\n100\tconst memberBioMock = {\n101\t  request: { query: DISPLAY_MEMBER_BIO, variables: { id: MEMBER_ID } },\n102\t  result: {\n103\t    data: {\n104\t      members: [\n105\t        {\n106\t          id: MEMBER_ID,\n107\t          firstName: 'Ama',\n108\t          middleName: '',\n109\t          lastName: 'Mensah',\n110\t          fullName: 'Ama Mensah',\n111\t          nameWithTitle: 'Ama Mensah',\n112\t          currentTitle: null,\n113\t          email: 'ama@example.com',\n114\t          phoneNumber: '233241111111',\n115\t          stickyNote: '',\n116\t          pictureUrl: 'https://example.com/pic.jpg',\n117\t          visitationArea: 'no-location',\n118\t          whatsappNumber: '233241111111',\n119\t          dob: { date: '1990-01-01' },\n120\t          gender: { gender: 'Female' },\n121\t          maritalStatus: { status: 'Single' },\n122\t          occupation: { occupation: 'Teacher' },\n123\t        },\n124\t      ],\n125\t    },\n126\t  },\n127\t}\n128\t\n129\tconst memberChurchMock = {\n130\t  request: { query: DISPLAY_MEMBER_CHURCH, variables: { id: MEMBER_ID } },\n131\t  result: {\n132\t    data: {\n133\t      members: [\n134\t        {\n135\t          id: MEMBER_ID,\n136\t          bacenta: {\n137\t            id: BACENTA_ID,\n138\t            name: 'Grace Bacenta',\n139\t            leader: { firstName: 'Kofi', lastName: 'Boateng' },\n140\t            council: {\n141\t              id: 'council-1',\n142\t              name: 'Central Council',\n143\t              leader: {\n144\t                id: 'leader-1',\n145\t                firstName: 'Kwame',\n146\t                lastName: 'Owusu',\n147\t                fullName: 'Kwame Owusu',\n148\t              },\n149\t            },\n150\t          },\n151\t          bacentaSummary: { id: BACENTA_ID, name: 'Grace Bacenta' },\n152\t          basonta: null,\n153\t          history: [],\n154\t        },\n155\t      ],\n156\t    },\n157\t  },\n158\t}\n159\t\n160\tconst basontasMock = {\n161\t  request: { query: GET_CAMPUS_BASONTAS, variables: { id: CAMPUS_ID } },\n162\t  result: {\n163\t    data: {\n164\t      campuses: [{ id: CAMPUS_ID, name: 'Main Campus', basontas: [] }],\n165\t    },\n166\t  },\n167\t}\n168\t\n169\t// SearchBacenta debounces (DEBOUNCE_TIMER=500ms) then always fires\n170\t// MEMBER_BACENTA_SEARCH for the initial bacenta name value seeded from\n171\t// memberChurchMock ('Grace Bacenta'). Match on the query alone (any\n172\t// variables) since the exact key/id aren't the point of this test and\n173\t// MockedProvider's default requires an exact variables match otherwise.\n174\tconst memberBacentaSearchMock = {\n175\t  request: { query: MEMBER_BACENTA_SEARCH },\n176\t  variableMatcher: () => true,\n177\t  result: {\n178\t    data: {\n179\t      members: [\n180\t        {\n181\t          id: MEMBER_ID,\n182\t          bacentaSearch: [\n183\t            { id: BACENTA_ID, name: 'Grace Bacenta', governorship: null },\n184\t          ],\n185\t        },\n186\t      ],\n187\t    },\n188\t  },\n189\t}\n190\t\n191\tconst collisionUpdateMock = (variables: Record<string, unknown>) => ({\n192\t  request: { query: UPDATE_MEMBER_MUTATION, variables },\n193\t  result: {\n194\t    data: { UpdateMemberDetails: null },\n195\t    errors: [\n196\t      {\n197\t        message: 'This email already belongs to another member',\n198\t        extensions: {\n199\t          collision: {\n200\t            field: 'email',\n201\t            status: 'active',\n202\t            memberId: 'other-member-1',\n203\t            firstName: 'Kofi',\n204\t            lastName: 'Asante',\n205\t            bacentaName: 'Faith Bacenta',\n206\t          },\n207\t        },\n208\t      },\n209\t    ],\n210\t  },\n211\t})\n212\t\n213\tconst genericErrorUpdateMock = (variables: Record<string, unknown>) => ({\n214\t  request: { query: UPDATE_MEMBER_MUTATION, variables },\n215\t  result: {\n216\t    data: { UpdateMemberDetails: null },\n217\t    errors: [\n218\t      {\n219\t        message: 'Something went wrong saving this member',\n220\t      },\n221\t    ],\n222\t  },\n223\t})\n224\t\n225\tconst successUpdateMock = (variables: Record<string, unknown>) => ({\n226\t  request: { query: UPDATE_MEMBER_MUTATION, variables },\n227\t  result: {\n228\t    data: {\n229\t      UpdateMemberDetails: {\n230\t        firstName: 'Ama',\n231\t        middleName: '',\n232\t        lastName: 'Mensah',\n233\t        fullName: 'Ama Mensah',\n234\t        email: (variables.email as string) ?? 'ama@example.com',\n235\t        phoneNumber: '233241111111',\n236\t        pictureUrl: 'https://example.com/pic.jpg',\n237\t        whatsappNumber: '233241111111',\n238\t        dob: { date: '1990-01-01' },\n239\t        gender: { gender: 'Female' },\n240\t        maritalStatus: { status: 'Single' },\n241\t        occupation: { occupation: 'Teacher' },\n242\t      },\n243\t    },\n244\t  },\n245\t})\n246\t\n247\tconst baseUpdateVariables = (email: string) => ({\n248\t  id: MEMBER_ID,\n249\t  firstName: 'Ama',\n250\t  middleName: '',\n251\t  lastName: 'Mensah',\n252\t  email,\n253\t  gender: 'Female',\n254\t  phoneNumber: '233241111111',\n255\t  whatsappNumber: '233241111111',\n256\t  dob: '1990-01-01',\n257\t  maritalStatus: 'Single',\n258\t  occupation: 'Teacher',\n259\t  pictureUrl: 'https://example.com/pic.jpg',\n260\t  bacenta: BACENTA_ID,\n261\t})\n262\t\n263\tconst renderUpdateMember = (mocks: readonly MockedResponse[]) =>\n264\t  render(\n265\t    <MemoryRouter initialEntries={['/member/edit']}>\n266\t      <MemberContext.Provider\n267\t        value={{\n268\t          memberId: MEMBER_ID,\n269\t          setMemberId: vi.fn(),\n270\t          // canChangeUniques() in MemberForm gates the Basic Info/Contact\n271\t          // sections (where the email field lives) on\n272\t          // isAuthorised(permitAdmin('Governorship'), currentUser.roles).\n273\t          currentUser: { id: 'tester-1', roles: ['adminGovernorship'] },\n274\t        }}\n275\t      >\n276\t        <ChurchContext.Provider value={{ campusId: CAMPUS_ID }}>\n277\t          <MockedProvider\n278\t            mocks={mocks}\n279\t            addTypename={false}\n280\t            defaultOptions={{\n281\t              // Mirrors prod's createApolloClient defaultOptions.mutate:\n282\t              // GraphQL errors land in `result.errors`, they do not reject\n283\t              // the mutate() promise.\n284\t              mutate: { errorPolicy: 'all' },\n285\t              watchQuery: { errorPolicy: 'all' },\n286\t              query: { errorPolicy: 'all' },\n287\t            }}\n288\t          >\n289\t            <UpdateMember />\n290\t          </MockedProvider>\n291\t        </ChurchContext.Provider>\n292\t      </MemberContext.Provider>\n293\t    </MemoryRouter>\n294\t  )\n295\t\n296\t// SearchBacenta only writes to Formik's `bacenta` field via the search\n297\t// dropdown's onSelect — the initial value only seeds the *display text*,\n298\t// not formik.values.bacenta. A real user re-confirms the bacenta by\n299\t// picking it from the dropdown; do the same here so submission has a\n300\t// valid `bacenta` object regardless of query-resolution timing.\n301\tconst selectBacentaFromDropdown = async () => {\n302\t  const user = userEvent.setup()\n303\t  const bacentaInput = await screen.findByPlaceholderText(\n304\t    /start typing to search/i\n305\t  )\n306\t  await user.click(bacentaInput)\n307\t  await user.clear(bacentaInput)\n308\t  await user.type(bacentaInput, 'Grace')\n309\t  const option = await screen.findByText('Grace Bacenta')\n310\t  await user.click(option)\n311\t}\n312\t\n313\tconst submitForm = async () => {\n314\t  const user = userEvent.setup()\n315\t  const submitButton = await screen.findByRole('button', { name: /save/i })\n316\t  await user.click(submitButton)\n317\t}\n318\t\n319\tdescribe('UpdateMember — SYN-205 email-collision handling', () => {\n320\t  it('shows the collision dialog (does not navigate away) when the update returns a collision error', async () => {\n321\t    const variables = baseUpdateVariables('taken@example.com')\n322\t\n323\t    renderUpdateMember([\n324\t      memberBioMock,\n325\t      memberChurchMock,\n326\t      basontasMock,\n327\t      memberBacentaSearchMock,\n328\t      collisionUpdateMock(variables),\n329\t      // UpdateMember's useMutation always sets refetchQueries for these two\n330\t      // queries. Since errorPolicy: 'all' means mutate() resolves (rather\n331\t      // than rejects) even on a collision error, Apollo still runs the\n332\t      // refetch — so a second copy of each read is needed here too.\n333\t      memberBioMock,\n334\t      memberChurchMock,\n335\t    ])\n336\t\n337\t    await screen.findByDisplayValue('ama@example.com')\n338\t    await selectBacentaFromDropdown()\n339\t\n340\t    const emailInput = screen.getByLabelText(/email address/i)\n341\t    await userEvent.setup().clear(emailInput)\n342\t    await userEvent.setup().type(emailInput, 'taken@example.com')\n343\t\n344\t    await submitForm()\n345\t\n346\t    const description = await screen.findByText(\n347\t      (_, element) =>\n348\t        element?.getAttribute('data-slot') === 'dialog-description' &&\n349\t        (element?.textContent ?? '').includes('already belongs to')\n350\t    )\n351\t    expect(description).toBeInTheDocument()\n352\t    expect(screen.getByText(/Kofi Asante/)).toBeInTheDocument()\n353\t\n354\t    // The whole point of the bug: this must NOT have fired.\n355\t    expect(mockNavigate).not.toHaveBeenCalled()\n356\t  })\n357\t\n358\t  it('navigates away on a genuine successful update', async () => {\n359\t    const variables = baseUpdateVariables('newemail@example.com')\n360\t\n361\t    renderUpdateMember([\n362\t      memberBioMock,\n363\t      memberChurchMock,\n364\t      basontasMock,\n365\t      memberBacentaSearchMock,\n366\t      successUpdateMock(variables),\n367\t      memberBioMock,\n368\t      memberChurchMock,\n369\t    ])\n370\t\n371\t    await screen.findByDisplayValue('ama@example.com')\n372\t    await selectBacentaFromDropdown()\n373\t\n374\t    const emailInput = screen.getByLabelText(/email address/i)\n375\t    await userEvent.setup().clear(emailInput)\n376\t    await userEvent.setup().type(emailInput, 'newemail@example.com')\n377\t\n378\t    await submitForm()\n379\t\n380\t    await waitFor(() =>\n381\t      expect(mockNavigate).toHaveBeenCalledWith('/member/displaydetails')\n382\t    )\n383\t  })\n384\t\n385\t  it('shows a real error toast (does not navigate away) for a non-collision GraphQL error', async () => {\n386\t    const variables = baseUpdateVariables('newemail@example.com')\n387\t\n388\t    renderUpdateMember([\n389\t      memberBioMock,\n390\t      memberChurchMock,\n391\t      basontasMock,\n392\t      memberBacentaSearchMock,\n393\t      genericErrorUpdateMock(variables),\n394\t      memberBioMock,\n395\t      memberChurchMock,\n396\t    ])\n397\t\n398\t    await screen.findByDisplayValue('ama@example.com')\n399\t    await selectBacentaFromDropdown()\n400\t\n401\t    const emailInput = screen.getByLabelText(/email address/i)\n402\t    await userEvent.setup().clear(emailInput)\n403\t    await userEvent.setup().type(emailInput, 'newemail@example.com')\n404\t\n405\t    await submitForm()\n406\t\n407\t    // This is the branch that used to render \"[object Object]\" — displayError\n408\t    // must be passed the real GraphQLFormattedError message, not the raw object.\n409\t    await waitFor(() =>\n410\t      expect(toast.error).toHaveBeenCalledWith(\n411\t        'There was an error updating the member profile',\n412\t        expect.objectContaining({\n413\t          description: 'Something went wrong saving this member',\n414\t        })\n415\t      )\n416\t    )\n417\t\n418\t    expect(mockNavigate).not.toHaveBeenCalled()\n419\t  })\n420\t})\n421\t"}]},"parent_tool_use_id":"toolu_016w2vuiZ6kjzmTmP565ciYV","session_id":"1f8dd599-a4b3-4691-9eeb-51a7fceb4862","uuid":"d9b8de5b-d1a2-4826-a5fc-8fb9b207b72e","timestamp":"2026-07-15T02:23:06.229Z","subagent_type":"code-reviewer","task_description":"Re-review SYN-205 fix after addressing findings"}
