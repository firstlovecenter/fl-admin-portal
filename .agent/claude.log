{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0119tymbRgG26jqcFJFu6FN3","type":"tool_result","content":"1\t// eslint-disable-next-line @typescript-eslint/ban-ts-comment\n2\t// @ts-nocheck\n3\t/* eslint-disable no-relative-import-paths/no-relative-import-paths */\n4\timport { GraphQLError } from 'graphql'\n5\timport { QueryResult } from 'neo4j-driver'\n6\timport { ChurchLevel, Member, neonumber, Role } from './types'\n7\t\n8\t// `GraphQLError` (not a plain Error with `error.extensions` set) is required so\n9\t// Apollo Server 4's default formatError preserves `extensions.code` once\n10\t// NODE_ENV=production — without this the FE always sees INTERNAL_SERVER_ERROR.\n11\texport const badRequest = (message: string): GraphQLError =>\n12\t  new GraphQLError(message, {\n13\t    extensions: { code: 'BAD_USER_INPUT', severity: 'USER_ERROR' },\n14\t  })\n15\t\n16\t// Structured collision error for the member-edit path: instead of a flat\n17\t// \"already in use\" dead-end, carry the colliding member's identity + status in\n18\t// `extensions.collision` so the FE can surface them and offer the right action\n19\t// (reactivate a deactivated member, or explain the transfer route for an active\n20\t// one). Still BAD_USER_INPUT so Apollo preserves the code in production.\n21\texport const memberContactCollisionError = (\n22\t  field: 'email' | 'whatsappNumber',\n23\t  clash: {\n24\t    id: string\n25\t    firstName: string\n26\t    lastName: string\n27\t    isActive: boolean\n28\t    bacentaName: string | null\n29\t  }\n30\t): GraphQLError => {\n31\t  const who = `${clash.firstName} ${clash.lastName}`\n32\t  const fieldLabel = field === 'email' ? 'email' : 'WhatsApp number'\n33\t  const message = clash.isActive\n34\t    ? `This ${fieldLabel} already belongs to ${who}${\n35\t        clash.bacentaName\n36\t          ? `, a registered member at ${clash.bacentaName} Bacenta`\n37\t          : ', a registered member'\n38\t      }. To bring them here, request a transfer.`\n39\t    : `This ${fieldLabel} belongs to ${who}, a deactivated member. You can reactivate their profile.`\n40\t\n41\t  return new GraphQLError(message, {\n42\t    extensions: {\n43\t      code: 'BAD_USER_INPUT',\n44\t      severity: 'USER_ERROR',\n45\t      collision: {\n46\t        field,\n47\t        status: clash.isActive ? 'active' : 'inactive',\n48\t        memberId: clash.id,\n49\t        firstName: clash.firstName,\n50\t        lastName: clash.lastName,\n51\t        bacentaName: clash.bacentaName ?? null,\n52\t      },\n53\t    },\n54\t  })\n55\t}\n56\t\n57\texport const isClassifiedError = (err: unknown): boolean => {\n58\t  const code = (err as { extensions?: { code?: string } })?.extensions?.code\n59\t  return code === 'BAD_USER_INPUT' || code === 'FORBIDDEN'\n60\t}"}]},"parent_tool_use_id":"toolu_01JoefhpidbdwCMGm8obaPNk","session_id":"1f8dd599-a4b3-4691-9eeb-51a7fceb4862","uuid":"d2bd7d60-1ad1-4bad-bf80-a43baf246de4","timestamp":"2026-07-15T02:07:50.503Z","subagent_type":"security-reviewer","task_description":"Security review of SYN-205 email update fix"}
