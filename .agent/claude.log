{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EaQV5z4FD1W1FbCr6frdRv","type":"tool_result","content":"1\timport { ApolloError } from '@apollo/client'\n2\timport { toast } from 'sonner'\n3\t\n4\t/**\n5\t * Extracts the first meaningful error message from a GraphQL error\n6\t * Handles permission errors, validation errors, and other GraphQL errors\n7\t */\n8\texport const getGraphQLErrorMessage = (error: unknown): string => {\n9\t  if (!error) return 'An unknown error occurred'\n10\t\n11\t  if (error instanceof ApolloError) {\n12\t    // First, try to get the most relevant GraphQL error message\n13\t    if (error.graphQLErrors && error.graphQLErrors.length > 0) {\n14\t      // Look for permission or permission-related errors first\n15\t      const permissionError = error.graphQLErrors.find((err) =>\n16\t        err.message.toLowerCase().includes('permit')\n17\t      )\n18\t      if (permissionError) {\n19\t        return permissionError.message\n20\t      }\n21\t\n22\t      // Return the first error if no specific type found\n23\t      return error.graphQLErrors[0].message\n24\t    }\n25\t\n26\t    // Fall back to network error if no graphQL errors\n27\t    if (error.networkError) {\n28\t      return error.networkError.message\n29\t    }\n30\t  }\n31\t\n32\t  if (error instanceof Error) {\n33\t    return error.message\n34\t  }\n35\t\n36\t  // Plain GraphQLFormattedError objects (e.g. useMutation's `result.errors`\n37\t  // under errorPolicy: 'all') aren't Error instances — read `.message`\n38\t  // directly so callers don't fall through to `String(error)` → \"[object Object]\".\n39\t  if (\n40\t    typeof error === 'object' &&\n41\t    error !== null &&\n42\t    'message' in error &&\n43\t    typeof (error as { message: unknown }).message === 'string'\n44\t  ) {\n45\t    return (error as { message: string }).message\n46\t  }\n47\t\n48\t  return String(error)\n49\t}\n50\t\n51\t/**\n52\t * Displays an error using industry-standard snackbar notification\n53\t * This provides consistent error feedback across the application\n54\t */\n55\texport const displayError = (\n56\t  title: string,\n57\t  error: unknown,\n58\t  duration = 15000\n59\t) => {\n60\t  const errorMessage = getGraphQLErrorMessage(error)\n61\t\n62\t  toast.error(title, {\n63\t    id: `${title}:${errorMessage}`,\n64\t    description: errorMessage,\n65\t    duration,\n66\t  })\n67\t}\n68\t\n69\t/**\n70\t * Extracts all GraphQL error messages from an ApolloError\n71\t * Useful for logging or detailed error handling\n72\t */\n73\texport const getAllGraphQLErrorMessages = (error: ApolloError): string[] => {\n74\t  if (!error.graphQLErrors || error.graphQLErrors.length === 0) {\n75\t    return []\n76\t  }\n77\t  return error.graphQLErrors.map((err) => err.message)\n78\t}\n79\t\n80\t/**\n81\t * Checks if an error is a permission/authorization error\n82\t */\n83\texport const isPermissionError = (error: unknown): boolean => {\n84\t  if (error instanceof ApolloError) {\n85\t    const message = getGraphQLErrorMessage(error).toLowerCase()\n86\t    return (\n87\t      message.includes('permit') ||\n88\t      message.includes('authorized') ||\n89\t      message.includes('unauthorized')\n90\t    )\n91\t  }\n92\t  return false\n93\t}\n94\t"}]},"parent_tool_use_id":null,"session_id":"1f8dd599-a4b3-4691-9eeb-51a7fceb4862","uuid":"8b3d544a-6c0e-429e-b0b4-8ccb6eae4ffd","timestamp":"2026-07-15T02:34:22.387Z","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/.openclaw/workspace/repos/fl-admin-portal/web-react-ts/src/utils/errorHandler.ts","content":"import { ApolloError } from '@apollo/client'\nimport { toast } from 'sonner'\n\n/**\n * Extracts the first meaningful error message from a GraphQL error\n * Handles permission errors, validation errors, and other GraphQL errors\n */\nexport const getGraphQLErrorMessage = (error: unknown): string => {\n  if (!error) return 'An unknown error occurred'\n\n  if (error instanceof ApolloError) {\n    // First, try to get the most relevant GraphQL error message\n    if (error.graphQLErrors && error.graphQLErrors.length > 0) {\n      // Look for permission or permission-related errors first\n      const permissionError = error.graphQLErrors.find((err) =>\n        err.message.toLowerCase().includes('permit')\n      )\n      if (permissionError) {\n        return permissionError.message\n      }\n\n      // Return the first error if no specific type found\n      return error.graphQLErrors[0].message\n    }\n\n    // Fall back to network error if no graphQL errors\n    if (error.networkError) {\n      return error.networkError.message\n    }\n  }\n\n  if (error instanceof Error) {\n    return error.message\n  }\n\n  // Plain GraphQLFormattedError objects (e.g. useMutation's `result.errors`\n  // under errorPolicy: 'all') aren't Error instances — read `.message`\n  // directly so callers don't fall through to `String(error)` → \"[object Object]\".\n  if (\n    typeof error === 'object' &&\n    error !== null &&\n    'message' in error &&\n    typeof (error as { message: unknown }).message === 'string'\n  ) {\n    return (error as { message: string }).message\n  }\n\n  return String(error)\n}\n\n/**\n * Displays an error using industry-standard snackbar notification\n * This provides consistent error feedback across the application\n */\nexport const displayError = (\n  title: string,\n  error: unknown,\n  duration = 15000\n) => {\n  const errorMessage = getGraphQLErrorMessage(error)\n\n  toast.error(title, {\n    id: `${title}:${errorMessage}`,\n    description: errorMessage,\n    duration,\n  })\n}\n\n/**\n * Extracts all GraphQL error messages from an ApolloError\n * Useful for logging or detailed error handling\n */\nexport const getAllGraphQLErrorMessages = (error: ApolloError): string[] => {\n  if (!error.graphQLErrors || error.graphQLErrors.length === 0) {\n    return []\n  }\n  return error.graphQLErrors.map((err) => err.message)\n}\n\n/**\n * Checks if an error is a permission/authorization error\n */\nexport const isPermissionError = (error: unknown): boolean => {\n  if (error instanceof ApolloError) {\n    const message = getGraphQLErrorMessage(error).toLowerCase()\n    return (\n      message.includes('permit') ||\n      message.includes('authorized') ||\n      message.includes('unauthorized')\n    )\n  }\n  return false\n}\n","numLines":94,"startLine":1,"totalLines":94}}}
