{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XCnq6hnWDSg1EMXeQgsD7E","type":"tool_result","content":"1\timport React, { useContext, useState } from 'react'\n2\timport { useNavigate } from 'react-router-dom'\n3\timport { useQuery, useMutation } from '@apollo/client'\n4\t\n5\timport { parsePhoneNum, throwToSentry } from 'global-utils'\n6\timport { displayError } from 'utils/errorHandler'\n7\timport {\n8\t  UPDATE_MEMBER_MUTATION,\n9\t  UPDATE_MEMBER_BACENTA,\n10\t  UPDATE_MEMBER_BASONTA,\n11\t  REACTIVATE_MEMBER_TO_BACENTA,\n12\t} from './UpdateMutations'\n13\timport {\n14\t  DISPLAY_MEMBER_BIO,\n15\t  DISPLAY_MEMBER_CHURCH,\n16\t} from '../display/ReadQueries'\n17\t\n18\timport { MemberContext } from 'contexts/MemberContext'\n19\timport MemberForm from '../reusable-forms/MemberForm'\n20\timport { CreateMemberFormOptions } from '../create/CreateMember'\n21\timport { FormikHelpers } from 'formik'\n22\timport MemberCollisionDialog, { MemberCollision } from './MemberCollisionDialog'\n23\t\n24\ttype CollisionExtension = { collision?: MemberCollision }\n25\t\n26\t// Shared by the errorPolicy: 'all' result.errors path and the catch-block's\n27\t// graphQLErrors path — both carry the collision the same way.\n28\tconst extractCollision = (\n29\t  errors: readonly { extensions?: unknown }[] | undefined\n30\t): MemberCollision | undefined =>\n31\t  errors\n32\t    ?.map((err) => (err.extensions as CollisionExtension | undefined)?.collision)\n33\t    .find((collision): collision is MemberCollision => Boolean(collision))\n34\t\n35\tconst UpdateMember = () => {\n36\t  const { memberId, setMemberId } = useContext(MemberContext)\n37\t  const [collision, setCollision] = useState<MemberCollision | null>(null)\n38\t\n39\t  const {\n40\t    data: memberData,\n41\t    error: memberError,\n42\t    loading: memberLoading,\n43\t  } = useQuery(DISPLAY_MEMBER_BIO, {\n44\t    variables: { id: memberId },\n45\t  })\n46\t  const error: any = memberError\n47\t  const { data: churchData } = useQuery(DISPLAY_MEMBER_CHURCH, {\n48\t    variables: { id: memberId },\n49\t  })\n50\t  const member = memberData?.members[0]\n51\t  const memberChurch = churchData?.members[0]\n52\t\n53\t  const initialValues: CreateMemberFormOptions = {\n54\t    firstName: member?.firstName ?? '',\n55\t    middleName: member?.middleName ?? '',\n56\t    lastName: member?.lastName ?? '',\n57\t    gender: member?.gender?.gender ?? '',\n58\t    phoneNumber: member?.phoneNumber ? `+${member?.phoneNumber}` : '',\n59\t    whatsappNumber: member?.whatsappNumber ? `+${member?.whatsappNumber}` : '',\n60\t    email: member?.email ?? '',\n61\t    dob: member?.dob ? member.dob.date : '',\n62\t    maritalStatus: member?.maritalStatus?.status ?? '',\n63\t    occupation: member?.occupation?.occupation ?? '',\n64\t    pictureUrl: member?.pictureUrl ?? '',\n65\t    visitationArea: member?.visitationArea ?? 'no-location',\n66\t    bacenta: memberChurch?.bacenta,\n67\t    basonta: memberChurch?.basonta?.id ?? '',\n68\t  }\n69\t\n70\t  const navigate = useNavigate()\n71\t\n72\t  const [UpdateMember] = useMutation(UPDATE_MEMBER_MUTATION, {\n73\t    refetchQueries: [\n74\t      { query: DISPLAY_MEMBER_BIO, variables: { id: memberId } },\n75\t      { query: DISPLAY_MEMBER_CHURCH, variables: { id: memberId } },\n76\t    ],\n77\t  })\n78\t  const [UpdateMemberBacenta] = useMutation(UPDATE_MEMBER_BACENTA)\n79\t  const [UpdateMemberBasonta] = useMutation(UPDATE_MEMBER_BASONTA)\n80\t  const [ReactivateMember, { loading: reactivating }] = useMutation(\n81\t    REACTIVATE_MEMBER_TO_BACENTA\n82\t  )\n83\t\n84\t  const onReactivate = async () => {\n85\t    if (!collision?.targetBacentaId) {\n86\t      displayError(\n87\t        'Cannot reactivate',\n88\t        new Error('Select a bacenta for this member before reactivating.')\n89\t      )\n90\t      return\n91\t    }\n92\t\n93\t    try {\n94\t      const res = await ReactivateMember({\n95\t        variables: {\n96\t          memberId: collision.memberId,\n97\t          bacentaId: collision.targetBacentaId,\n98\t        },\n99\t      })\n100\t\n101\t      const reactivatedId =\n102\t        res.data?.ReactivateMemberToBacenta?.id ?? collision.memberId\n103\t\n104\t      setCollision(null)\n105\t      setMemberId(reactivatedId)\n106\t      navigate('/member/displaydetails')\n107\t    } catch (error: unknown) {\n108\t      displayError('There was an error reactivating the member', error)\n109\t    }\n110\t  }\n111\t\n112\t  const onSubmit = async (\n113\t    values: CreateMemberFormOptions,\n114\t    onSubmitProps: FormikHelpers<CreateMemberFormOptions>\n115\t  ) => {\n116\t    onSubmitProps.setSubmitting(true)\n117\t\n118\t    try {\n119\t      const updateResult = await UpdateMember({\n120\t        variables: {\n121\t          id: memberId,\n122\t          firstName: values.firstName.trim(),\n123\t          middleName: values.middleName.trim(),\n124\t          lastName: values.lastName.trim(),\n125\t          email: values.email?.trim().toLowerCase() || null,\n126\t          gender: values.gender,\n127\t          phoneNumber: parsePhoneNum(values.phoneNumber),\n128\t          whatsappNumber: parsePhoneNum(values.whatsappNumber),\n129\t          dob: values.dob,\n130\t          maritalStatus: values.maritalStatus,\n131\t          occupation: values.occupation,\n132\t          pictureUrl: values.pictureUrl,\n133\t\n134\t          bacenta: values.bacenta?.id,\n135\t        },\n136\t      })\n137\t\n138\t      // errorPolicy: 'all' (SYN-178) puts GraphQL errors in `.errors` rather\n139\t      // than rejecting the promise — see SYN-205: without this check, a\n140\t      // collision (or any other GraphQL error) was silently treated as a\n141\t      // success.\n142\t      if (updateResult.errors?.length) {\n143\t        onSubmitProps.setSubmitting(false)\n144\t\n145\t        const collisionInfo = extractCollision(updateResult.errors)\n146\t        if (collisionInfo) {\n147\t          setCollision({\n148\t            ...collisionInfo,\n149\t            targetBacentaId: values.bacenta?.id,\n150\t          })\n151\t          return\n152\t        }\n153\t\n154\t        displayError(\n155\t          'There was an error updating the member profile',\n156\t          new Error(updateResult.errors[0].message)\n157\t        )\n158\t        return\n159\t      }\n160\t\n161\t      if (memberChurch?.bacenta.id !== values.bacenta.id) {\n162\t        const bacentaResult = await UpdateMemberBacenta({\n163\t          variables: {\n164\t            memberId: memberId,\n165\t            bacentaId: values.bacenta?.id,\n166\t            ids: [memberId, values.bacenta?.id, memberChurch?.bacenta.id],\n167\t            historyRecord: `${member.firstName} ${member.lastName} moved from ${memberChurch?.bacenta.name} Bacenta to ${values.bacenta?.name} Bacenta`,\n168\t          },\n169\t        })\n170\t\n171\t        if (bacentaResult.errors?.length) {\n172\t          onSubmitProps.setSubmitting(false)\n173\t          displayError(\n174\t            \"There was an error updating the member's bacenta\",\n175\t            new Error(bacentaResult.errors[0].message)\n176\t          )\n177\t          return\n178\t        }\n179\t      }\n180\t\n181\t      if (values.basonta && memberChurch?.basonta?.id !== values.basonta) {\n182\t        const basontaResult = await UpdateMemberBasonta({\n183\t          variables: {\n184\t            memberId: memberId,\n185\t            basontaId: values.basonta,\n186\t          },\n187\t        })\n188\t\n189\t        if (basontaResult.errors?.length) {\n190\t          onSubmitProps.setSubmitting(false)\n191\t          displayError(\n192\t            \"There was an error updating the member's basonta\",\n193\t            new Error(basontaResult.errors[0].message)\n194\t          )\n195\t          return\n196\t        }\n197\t      }\n198\t\n199\t      onSubmitProps.setSubmitting(false)\n200\t      onSubmitProps.resetForm()\n201\t      navigate('/member/displaydetails')\n202\t    } catch (error: any) {\n203\t      onSubmitProps.setSubmitting(false)\n204\t\n205\t      const collisionInfo = extractCollision(error?.graphQLErrors)\n206\t\n207\t      if (collisionInfo) {\n208\t        setCollision({ ...collisionInfo, targetBacentaId: values.bacenta?.id })\n209\t        return\n210\t      }\n211\t\n212\t      throwToSentry('There was an error updating the member profile\\n', error)\n213\t    }\n214\t  }\n215\t\n216\t  if (error) {\n217\t    throwToSentry(error)\n218\t  }\n219\t\n220\t  return (\n221\t    <>\n222\t      <MemberForm\n223\t        initialValues={initialValues}\n224\t        onSubmit={onSubmit}\n225\t        loading={memberLoading}\n226\t        update\n227\t      />\n228\t      <MemberCollisionDialog\n229\t        collision={collision}\n230\t        reactivating={reactivating}\n231\t        onReactivate={onReactivate}\n232\t        onClose={() => setCollision(null)}\n233\t      />\n234\t    </>\n235\t  )\n236\t}\n237\t\n238\texport default UpdateMember\n239\t"}]},"parent_tool_use_id":"toolu_016w2vuiZ6kjzmTmP565ciYV","session_id":"1f8dd599-a4b3-4691-9eeb-51a7fceb4862","uuid":"647fa6ff-402e-40e4-afbe-d32a252901d0","timestamp":"2026-07-15T02:23:05.423Z","subagent_type":"code-reviewer","task_description":"Re-review SYN-205 fix after addressing findings"}
