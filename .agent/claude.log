{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NdYiCirF2kG5VEJhRNTbbu","type":"tool_result","content":"1\timport { getHumanReadableDate } from '../utils/date-utils'\n2\timport { Context } from '../utils/neo4j-types'\n3\timport { Member } from '../utils/types'\n4\timport {\n5\t  badRequest,\n6\t  isAuth,\n7\t  memberContactCollisionError,\n8\t  rearrangeCypherObject,\n9\t  throwToSentry,\n10\t} from '../utils/utils'\n11\timport {\n12\t  permitAdmin,\n13\t  permitLeaderAdmin,\n14\t  permitAdminArrivals,\n15\t} from '../permissions'\n16\timport { RemoveServant } from './make-remove-servants'\n17\t\n18\timport {\n19\t  makeMemberInactive,\n20\t  createMember,\n21\t  activateInactiveMember,\n22\t  removeDuplicateMember,\n23\t  updateMemberBacenta,\n24\t  createBacenta,\n25\t  createGovernorship,\n26\t  createCouncil,\n27\t  createStream,\n28\t  createCampus,\n29\t  createOversight,\n30\t} from '../cypher/resolver-cypher'\n31\timport { sendServantPromotionEmail } from '../utils/notify'\n32\timport { clearUserAuthorityCache } from '../utils/allowed-church-ids'\n33\timport { assertChurchScope, assertScopeViaMember } from '../utils/scope-utils'\n34\timport { assertCan } from '../utils/assert-can'\n35\t\n36\tconst cypher = require('../cypher/resolver-cypher')\n37\tconst closeChurchCypher = require('../cypher/close-church-cypher')\n38\tconst texts = require('../texts.json')\n39\t\n40\tconst directoryMutation = {\n41\t  CreateMember: async (object: any, args: Member, context: Context) => {\n42\t    isAuth(permitLeaderAdmin('Bacenta'), context?.jwt?.roles)\n43\t\n44\t    // isAuth only checks the caller HOLDS a bacenta-level role, not WHERE.\n45\t    // Gate the destination bacenta so a leader cannot create — or reactivate —\n46\t    // members into a bacenta outside their scope. Both the new-member and the\n47\t    // `activateInactiveMember` branches below attach to `$bacenta`, so scoping\n48\t    // it once here covers them both (SYN-186).\n49\t    await assertChurchScope(context, args.bacenta)\n50\t\n51\t    const session = context.executionContext.session()\n52\t    const email = args?.email?.trim().toLowerCase() || null\n53\t    const inactiveMemberResponse = rearrangeCypherObject(\n54\t      await session.executeRead((tx) =>\n55\t        tx.run(cypher.checkInactiveMember, {\n56\t          email,\n57\t          whatsappNumber: args?.whatsappNumber ?? null,\n58\t        })\n59\t      )\n60\t    )\n61\t\n62\t    if (inactiveMemberResponse.count > 0) {\n63\t      const activateInactiveMemberResponse = await session.executeWrite((tx) =>\n64\t        tx.run(activateInactiveMember, {\n65\t          id: inactiveMemberResponse.id,\n66\t          firstName: args?.firstName ?? '',\n67\t          middleName: args?.middleName ?? '',\n68\t          lastName: args?.lastName ?? '',\n69\t          phoneNumber: args?.phoneNumber ?? '',\n70\t          dob: args?.dob ?? '',\n71\t          maritalStatus: args?.maritalStatus ?? '',\n72\t          occupation: args?.occupation ?? '',\n73\t          bacenta: args?.bacenta ?? '',\n74\t          basonta: args?.basonta ?? '',\n75\t          visitationArea: args?.visitationArea ?? '',\n76\t          pictureUrl: args?.pictureUrl ?? '',\n77\t          userId: context.jwt?.userId,\n78\t        })\n79\t      )\n80\t\n81\t      const member = rearrangeCypherObject(activateInactiveMemberResponse)\n82\t      return member\n83\t    }\n84\t\n85\t    const memberResponse = await session.executeRead((tx) =>\n86\t      tx.run(cypher.checkMemberEmailExists, {\n87\t        email,\n88\t        whatsappNumber: args?.whatsappNumber ?? null,\n89\t      })\n90\t    )\n91\t    const memberCheck = rearrangeCypherObject(memberResponse, true)[0]\n92\t    const duplicateMember = memberCheck.member?.properties\n93\t\n94\t    if (memberCheck.predicate) {\n95\t      if (duplicateMember.email === email) {\n96\t        const errorMsg = `There is a member with this email \"${duplicateMember.email}\" called ${duplicateMember.firstName} ${duplicateMember.lastName}`\n97\t\n98\t        const error = new Error(errorMsg)\n99\t        error.name = 'DuplicateEmail'\n100\t\n101\t        throw error\n102\t      }\n103\t\n104\t      if (duplicateMember.whatsappNumber === args.whatsappNumber) {\n105\t        const errorMsg = `There is a member with this whatsapp number \"${duplicateMember.whatsappNumber}\" called ${duplicateMember.firstName} ${duplicateMember.lastName}`\n106\t        const error = new Error(errorMsg)\n107\t        error.name = 'DuplicateWhatsappNumber'\n108\t        throw error\n109\t      }\n110\t    }\n111\t\n112\t    const createMemberResponse = await session.executeWrite((tx) =>\n113\t      tx.run(createMember, {\n114\t        firstName: args?.firstName ?? '',\n115\t        middleName: args?.middleName ?? null,\n116\t        lastName: args?.lastName ?? '',\n117\t        email,\n118\t        phoneNumber: args?.phoneNumber ?? '',\n119\t        whatsappNumber: args?.whatsappNumber ?? '',\n120\t        dob: args?.dob ?? '',\n121\t        maritalStatus: args?.maritalStatus ?? '',\n122\t        gender: args?.gender ?? '',\n123\t        occupation: args?.occupation ?? '',\n124\t        bacenta: args?.bacenta ?? '',\n125\t        basonta: args?.basonta ?? '',\n126\t        visitationArea: args?.visitationArea ?? '',\n127\t        pictureUrl: args?.pictureUrl ?? '',\n128\t        userId: context.jwt?.userId,\n129\t      })\n130\t    )\n131\t\n132\t    const member = rearrangeCypherObject(createMemberResponse)\n133\t    await session.close()\n134\t\n135\t    return member\n136\t  },\n137\t  UpdateMemberDetails: async (object: any, args: Member, context: Context) => {\n138\t    isAuth(permitLeaderAdmin('Bacenta'), context?.jwt?.roles)\n139\t    const session = context.executionContext.session()\n140\t    const email = args?.email?.trim().toLowerCase() || null\n141\t\n142\t    try {\n143\t      // Reject an email / whatsapp already held by ANOTHER member with a\n144\t      // readable message — Member.email and Member.whatsappNumber are unique,\n145\t      // so the bare write would otherwise surface \"Constraint validation\n146\t      // failed\". Mirrors the CreateMember pre-check, but excludes self. The\n147\t      // query can return two different members (one per field), so check each\n148\t      // field against every returned row.\n149\t      const collisions = rearrangeCypherObject(\n150\t        await session.executeRead((tx) =>\n151\t          tx.run(cypher.checkMemberContactExistsOnOther, {\n152\t            id: args.id,\n153\t            email,\n154\t            whatsappNumber: args?.whatsappNumber ?? null,\n155\t          })\n156\t        ),\n157\t        true\n158\t      )\n159\t        .map((row: any) => ({\n160\t          ...(row?.member?.properties ?? {}),\n161\t          isActive: Boolean(row?.isActive),\n162\t          bacentaName: row?.bacentaName ?? null,\n163\t        }))\n164\t        .filter((m: any) => m.id)\n165\t\n166\t      const emailClash = email\n167\t        ? collisions.find((m: any) => m.email === email)\n168\t        : undefined\n169\t      if (emailClash) {\n170\t        throw memberContactCollisionError('email', emailClash)\n171\t      }\n172\t\n173\t      const whatsappClash = args.whatsappNumber\n174\t        ? collisions.find((m: any) => m.whatsappNumber === args.whatsappNumber)\n175\t        : undefined\n176\t      if (whatsappClash) {\n177\t        throw memberContactCollisionError('whatsappNumber', whatsappClash)\n178\t      }\n179\t\n180\t      const updateResponse = await session.executeWrite((tx) =>\n181\t        tx.run(cypher.updateMemberDetails, {\n182\t          id: args.id,\n183\t          firstName: args?.firstName ?? '',\n184\t          middleName: args?.middleName ?? null,\n185\t          lastName: args?.lastName ?? '',\n186\t          email,\n187\t          phoneNumber: args?.phoneNumber ?? '',\n188\t          whatsappNumber: args?.whatsappNumber ?? null,\n189\t          pictureUrl: args?.pictureUrl ?? '',\n190\t          gender: args?.gender ?? '',"}]},"parent_tool_use_id":"toolu_01JoefhpidbdwCMGm8obaPNk","session_id":"1f8dd599-a4b3-4691-9eeb-51a7fceb4862","uuid":"9a516f06-69c5-4fa7-b040-41e45b7e9236","timestamp":"2026-07-15T02:07:50.192Z","subagent_type":"security-reviewer","task_description":"Security review of SYN-205 email update fix"}
